        {# Left section: Logo/Title and main navigation #}
        <div class="flex items-center gap-8">
            {# Website Title/Logo #}
            <a href="{{ path('app_home') }}" class="text-xl font-bold uppercase tracking-widest font-['Space_Grotesk'] text-[#FF8C00] hover:text-[#ff9d26] transition-colors">
                ManaHoarder
            </a>

            {# Main Navigation Links #}
            <div class="hidden md:flex items-center gap-6">
                <a href="{{ path('app_decks') }}" class="text-[10px] font-bold uppercase tracking-widest text-zinc-400 hover:text-[#FF8C00] transition-colors font-['Space_Grotesk']">
