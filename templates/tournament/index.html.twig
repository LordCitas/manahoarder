{% extends 'base.html.twig' %}

{% block title %}Tournaments - ManaHoarder{% endblock %}

{% block body %}
<main class="min-h-screen">
    <div class="max-w-[1440px] mx-auto p-8 lg:p-12">
        <!-- Header Section -->
        <div class="mb-10 flex justify-between items-start">
            <div>
                <h1 class="font-['Space_Grotesk'] text-[40px] leading-[1.2] tracking-tighter font-bold text-[#FF8C00] mb-2 uppercase">Tournaments</h1>
                <p class="text-zinc-300 text-lg max-w-2xl">Create or join competitive Magic: The Gathering events.</p>
            </div>
            <div class="flex gap-3">
                <button onclick="document.getElementById('joinModal').classList.remove('hidden')" class="bg-zinc-900 border border-[#2A2A2A] text-zinc-300 px-5 py-3 rounded font-['Space_Grotesk'] text-xs font-bold uppercase tracking-wider hover:border-[#FF8C00]/50 transition-all flex items-center gap-2">
                    <span class="material-symbols-outlined text-sm">login</span>
                    Join with Code
                </button>
                <a href="{{ path('app_tournament_create') }}" class="bg-[#FF8C00] text-black px-5 py-3 rounded font-['Space_Grotesk'] text-xs font-bold uppercase tracking-wider hover:brightness-110 transition-all flex items-center gap-2">
                    <span class="material-symbols-outlined text-sm">add</span>
                    Create Tournament
                </a>
            </div>
        </div>

        <!-- Flash Messages -->
        {% for message in app.flashes('success') %}
            <div class="mb-6 bg-green-900/20 border border-green-900/60 text-green-100 px-6 py-4 rounded-xl flex items-center gap-3">
                <span class="material-symbols-outlined text-green-500">check_circle</span>
                <span class="font-['Space_Grotesk'] text-sm">{{ message|raw }}</span>
            </div>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <div class="mb-6 bg-red-900/20 border border-red-900/60 text-red-100 px-6 py-4 rounded-xl flex items-center gap-3">
                <span class="material-symbols-outlined text-red-500">error</span>
                <span class="font-['Space_Grotesk'] text-sm">{{ message }}</span>
            </div>
        {% endfor %}

        {% for message in app.flashes('warning') %}
            <div class="mb-6 bg-yellow-900/20 border border-yellow-900/60 text-yellow-100 px-6 py-4 rounded-xl flex items-center gap-3">
                <span class="material-symbols-outlined text-yellow-500">warning</span>
                <span class="font-['Space_Grotesk'] text-sm">{{ message }}</span>
            </div>
        {% endfor %}

        {% if myTournaments|length > 0 or joinedTournaments|length > 0 %}
            <!-- My Tournaments -->
            {% if myTournaments|length > 0 %}
                <div class="mb-10">
                    <h2 class="font-['Space_Grotesk'] text-2xl font-semibold text-white uppercase tracking-tight mb-6">My Tournaments</h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                        {% for tournament in myTournaments %}
                            <a href="{{ path('app_tournament_view', {id: tournament.id}) }}" class="bg-[#1A1B1E] border border-[#2A2A2A] hover:border-[#FF8C00]/50 transition-all rounded-xl p-5 group">
                                <div class="flex items-start justify-between mb-4">
                                    <h3 class="font-['Space_Grotesk'] text-lg font-semibold text-white group-hover:text-[#FF8C00] transition-colors">{{ tournament.name }}</h3>
                                    <span class="bg-[#FF8C00] text-black px-2 py-1 rounded text-xs font-bold uppercase tracking-wider font-['Space_Grotesk']">{{ tournament.format }}</span>
                                </div>
                                <div class="space-y-2 mb-4">
                                    <div class="flex items-center gap-2 text-sm text-zinc-400">
                                        <span class="material-symbols-outlined text-base">group</span>
                                        <span class="font-['Space_Grotesk']">{{ tournament.tournamentParticipants|length }} participants</span>
                                    </div>
                                    <div class="flex items-center gap-2 text-sm text-zinc-400">
                                        <span class="material-symbols-outlined text-base">calendar_today</span>
                                        <span class="font-['Space_Grotesk']">{{ tournament.createdAt|date('M d, Y') }}</span>
                                    </div>
                                </div>
                                <div class="pt-3 border-t border-zinc-800">
                                    <div class="flex items-center justify-between">
                                        <span class="text-xs text-zinc-500 font-['Space_Grotesk']">Tournament Code</span>
                                        <span class="text-sm text-[#FF8C00] font-bold font-['Space_Grotesk'] tracking-wider">{{ tournament.inviteCode }}</span>
                                    </div>
                                </div>
                            </a>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            <!-- Joined Tournaments -->
            {% if joinedTournaments|length > 0 %}
                <div>
                    <h2 class="font-['Space_Grotesk'] text-2xl font-semibold text-white uppercase tracking-tight mb-6">Joined Tournaments</h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                        {% for tournament in joinedTournaments %}
                            <a href="{{ path('app_tournament_view', {id: tournament.id}) }}" class="bg-[#1A1B1E] border border-[#2A2A2A] hover:border-[#FF8C00]/50 transition-all rounded-xl p-5 group">
                                <div class="flex items-start justify-between mb-4">
                                    <h3 class="font-['Space_Grotesk'] text-lg font-semibold text-white group-hover:text-[#FF8C00] transition-colors">{{ tournament.name }}</h3>
                                    <span class="bg-zinc-900 border border-zinc-700 text-zinc-300 px-2 py-1 rounded text-xs font-bold uppercase tracking-wider font-['Space_Grotesk']">{{ tournament.format }}</span>
                                </div>
                                <div class="space-y-2 mb-4">
                                    <div class="flex items-center gap-2 text-sm text-zinc-400">
                                        <span class="material-symbols-outlined text-base">person</span>
                                        <div class="flex items-center gap-2">
                                            {% if tournament.creator.profileArtUrl %}
                                                <img src="{{ tournament.creator.profileArtUrl }}" alt="{{ tournament.creator.nickname }}" class="w-5 h-5 rounded border border-[#2A2A2A]">
                                            {% elseif tournament.creator.profilePictureFilename %}
                                                <img src="/uploads/profile-pictures/{{ tournament.creator.profilePictureFilename }}" alt="{{ tournament.creator.nickname }}" class="w-5 h-5 rounded border border-[#2A2A2A] object-cover">
                                            {% else %}
                                                <div class="w-5 h-5 rounded bg-[#FF8C00]/20 border border-[#FF8C00] flex items-center justify-center text-[#FF8C00] text-xs font-bold">{{ tournament.creator.nickname|slice(0, 1)|upper }}</div>
                                            {% endif %}
                                            <span class="font-['Space_Grotesk']">Host: {{ tournament.creator.nickname }}</span>
                                        </div>
                                    </div>
                                    <div class="flex items-center gap-2 text-sm text-zinc-400">
                                        <span class="material-symbols-outlined text-base">group</span>
                                        <span class="font-['Space_Grotesk']">{{ tournament.tournamentParticipants|length }} participants</span>
                                    </div>
                                    <div class="flex items-center gap-2 text-sm text-zinc-400">
                                        <span class="material-symbols-outlined text-base">calendar_today</span>
                                        <span class="font-['Space_Grotesk']">{{ tournament.createdAt|date('M d, Y') }}</span>
                                    </div>
                                    <div class="flex items-center gap-2 text-sm text-zinc-400">
                                        <span class="material-symbols-outlined text-base">bookmark</span>
                                        <span class="font-['Space_Grotesk']">{{ tournament.state|upper }}</span>
                                    </div>
                                </div>
                            </a>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

        {% else %}
            <!-- Empty State -->
            <div class="flex items-center justify-center min-h-[60vh]">
                <div class="text-center max-w-md">
                    <div class="w-24 h-24 rounded-full bg-zinc-900 border border-[#2A2A2A] flex items-center justify-center mx-auto mb-6">
                        <span class="material-symbols-outlined text-5xl text-zinc-600">emoji_events</span>
                    </div>
                    <h2 class="font-['Space_Grotesk'] text-2xl font-semibold text-white mb-3 uppercase tracking-tight">No Tournaments Yet</h2>
                    <p class="text-zinc-300 text-base mb-8">Create your first tournament or join an existing one using a tournament code.</p>
                    
                    <div class="flex flex-col sm:flex-row gap-3 justify-center">
                        <a href="{{ path('app_tournament_create') }}" class="bg-[#FF8C00] text-black px-6 py-3 rounded font-['Space_Grotesk'] text-xs font-bold uppercase tracking-wider hover:brightness-110 transition-all flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined text-sm">add</span>
                            Create Tournament
                        </a>
                        <button onclick="document.getElementById('joinModal').classList.remove('hidden')" class="bg-zinc-900 border border-[#2A2A2A] text-zinc-300 px-6 py-3 rounded font-['Space_Grotesk'] text-xs font-bold uppercase tracking-wider hover:border-[#FF8C00]/50 transition-all flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined text-sm">login</span>
                            Join with Code
                        </button>
                    </div>

                    <div class="mt-8 p-4 bg-[rgba(18,18,18,0.7)] backdrop-blur-xl border border-[#2A2A2A] rounded-xl">
                        <div class="flex items-start gap-3">
                            <span class="material-symbols-outlined text-[#FF8C00] text-xl">info</span>
                            <div class="text-left">
                                <h3 class="font-['Space_Grotesk'] text-sm font-semibold text-white mb-1 uppercase tracking-wide">How It Works</h3>
                                <p class="text-xs text-zinc-400">Create a tournament and share the code with players. They can join using the code and compete in your event.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        {% endif %}
    </div>
</main>

<!-- Join Tournament Modal -->
<div id="joinModal" class="hidden fixed inset-0 bg-black/80 backdrop-blur-sm z-50 flex items-center justify-center p-4">
    <div class="bg-[#121212] border border-[#2A2A2A] rounded-xl max-w-md w-full p-6">
        <div class="flex items-center justify-between mb-6">
            <h2 class="font-['Space_Grotesk'] text-xl font-bold text-white uppercase tracking-tight">Join Tournament</h2>
            <button onclick="document.getElementById('joinModal').classList.add('hidden')" class="text-zinc-500 hover:text-white transition-colors">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        
        <form method="post" action="{{ path('app_tournament_join_by_code') }}">
            <div class="mb-6">
                <label class="block text-xs font-bold uppercase tracking-widest text-zinc-400 font-['Space_Grotesk'] mb-2">Tournament Code</label>
                <input 
                    type="text" 
                    name="code"
                    placeholder="Enter 8-character code" 
                    maxlength="8"
                    class="w-full bg-[#1A1B1E] border border-[#2A2A2A] py-3 px-4 text-lg text-zinc-200 placeholder-zinc-600 font-['Space_Grotesk'] tracking-widest uppercase focus:border-[#FF8C00] outline-none rounded text-center"
                    required
                    autofocus
                >
            </div>
            
            <button type="submit" class="w-full bg-[#FF8C00] text-black px-6 py-3 rounded font-['Space_Grotesk'] text-sm font-bold uppercase tracking-wider hover:brightness-110 transition-all">
                Join Tournament
            </button>
        </form>
    </div>
</div>

<script>
    // Close modal when clicking outside
    document.getElementById('joinModal').addEventListener('click', function(e) {
        if (e.target === this) {
            this.classList.add('hidden');
        }
    });
</script>
{% endblock %}
