{% extends 'base.html.twig' %}

{% block title %}{{ tournament.name }} - ManaHoarder{% endblock %}

{% block body %}
<main class="min-h-screen">
    <div class="max-w-[1440px] mx-auto p-8 lg:p-12">
        
        <!-- Back Button -->
        <div class="mb-6">
            <a href="{{ path('app_tournaments') }}" class="inline-flex items-center gap-2 text-zinc-300 hover:text-[#FF8C00] transition-colors text-sm font-['Space_Grotesk'] uppercase tracking-wider">
                <span class="material-symbols-outlined">arrow_back</span>
                Back to Tournaments
            </a>
        </div>

        <!-- Header -->
        <div class="mb-8 flex justify-between items-start">
            <div>
                <h1 class="font-['Space_Grotesk'] text-[40px] leading-[1.2] tracking-tighter font-bold text-[#FF8C00] mb-2 uppercase">{{ tournament.name }}</h1>
                <div class="flex items-center gap-4">
                    <span class="bg-[#FF8C00] text-black px-3 py-1 rounded text-xs font-bold uppercase tracking-wider font-['Space_Grotesk']">{{ tournament.format }}</span>
                    <span class="bg-zinc-900 border border-zinc-700 text-zinc-300 px-3 py-1 rounded text-xs font-bold uppercase tracking-wider font-['Space_Grotesk']">{{ tournament.state|upper }}</span>
                </div>
            </div>
            {% if isCreator %}
                {% if tournament.state == 'draft' %}
                    <form method="post" action="{{ path('app_tournament_start', {id: tournament.id}) }}" class="flex gap-2">
                        <button type="submit" class="bg-[#FF8C00] text-black px-5 py-3 rounded font-['Space_Grotesk'] text-xs font-bold uppercase tracking-wider hover:brightness-110 transition-all flex items-center gap-2">
                            <span class="material-symbols-outlined text-sm">play_arrow</span>
                            Start Tournament
                        </button>
                    </form>
                {% endif %}
            {% endif %}
        </div>

        <!-- Flash Messages -->
        {% for message in app.flashes('success') %}
            <div class="mb-6 bg-green-900/20 border border-green-900/60 text-green-100 px-6 py-4 rounded-xl flex items-center gap-3">
                <span class="material-symbols-outlined text-green-500">check_circle</span>
                <span class="font-['Space_Grotesk'] text-sm">{{ message }}</span>
            </div>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <div class="mb-6 bg-red-900/20 border border-red-900/60 text-red-100 px-6 py-4 rounded-xl flex items-center gap-3">
                <span class="material-symbols-outlined text-red-500">error</span>
                <span class="font-['Space_Grotesk'] text-sm">{{ message }}</span>
            </div>
        {% endfor %}

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-10">
            <!-- Main Info -->
            <div class="lg:col-span-2">
                <!-- Tournament Details -->
                <div class="bg-[rgba(18,18,18,0.7)] backdrop-blur-xl border border-[#2A2A2A] p-6 rounded-xl mb-6">
                    <h2 class="text-sm font-bold uppercase tracking-widest text-zinc-400 font-['Space_Grotesk'] mb-4">Tournament Information</h2>
                    
                    <div class="space-y-4">
                        <div>
                            <p class="text-xs text-zinc-500 font-['Space_Grotesk'] uppercase tracking-wider mb-1">Organizer</p>
                            <p class="text-sm text-zinc-200 font-['Space_Grotesk']">{{ tournament.creator.email }}</p>
                        </div>
                        
                        <div>
                            <p class="text-xs text-zinc-500 font-['Space_Grotesk'] uppercase tracking-wider mb-1">Format</p>
                            <p class="text-sm text-zinc-200 font-['Space_Grotesk']">{{ tournament.format }}</p>
                        </div>
                        
                        <div>
                            <p class="text-xs text-zinc-500 font-['Space_Grotesk'] uppercase tracking-wider mb-1">Created</p>
                            <p class="text-sm text-zinc-200 font-['Space_Grotesk']">{{ tournament.createdAt|date('M d, Y H:i') }}</p>
                        </div>
                        
                        {% if tournament.startDate %}
                            <div>
                                <p class="text-xs text-zinc-500 font-['Space_Grotesk'] uppercase tracking-wider mb-1">Started</p>
                                <p class="text-sm text-zinc-200 font-['Space_Grotesk']">{{ tournament.startDate|date('M d, Y H:i') }}</p>
                            </div>
                        {% endif %}
                        
                        {% if tournament.description %}
                            <div>
                                <p class="text-xs text-zinc-500 font-['Space_Grotesk'] uppercase tracking-wider mb-1">Description</p>
                                <p class="text-sm text-zinc-200 font-['Space_Grotesk']">{{ tournament.description }}</p>
                            </div>
                        {% endif %}
                    </div>
                </div>

                <!-- Participants / Standings -->
                <div class="bg-[rgba(18,18,18,0.7)] backdrop-blur-xl border border-[#2A2A2A] p-6 rounded-xl">
                    <h2 class="text-sm font-bold uppercase tracking-widest text-zinc-400 font-['Space_Grotesk'] mb-4">Players ({{ participants|length }}/{{ tournament.maxPlayers }})</h2>
                    
                    {% if participants|length > 0 %}
                        <div class="overflow-x-auto">
                            <table class="w-full text-sm font-['Space_Grotesk']">
                                <thead>
                                    <tr class="border-b border-zinc-700">
                                        <th class="text-left text-xs text-zinc-500 uppercase tracking-wider py-2 px-2">#</th>
                                        <th class="text-left text-xs text-zinc-500 uppercase tracking-wider py-2 px-2">Player</th>
                                        <th class="text-left text-xs text-zinc-500 uppercase tracking-wider py-2 px-2">Decklist</th>
                                        <th class="text-center text-xs text-zinc-500 uppercase tracking-wider py-2 px-2">Wins</th>
                                        <th class="text-center text-xs text-zinc-500 uppercase tracking-wider py-2 px-2">Losses</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for participant in participants %}
                                        <tr class="border-b border-zinc-800 hover:bg-zinc-900/50 transition-colors">
                                            <td class="py-3 px-2 text-[#FF8C00] font-bold">{{ loop.index }}</td>
                                            <td class="py-3 px-2 text-zinc-200">{{ participant.user.email }}</td>
                                            <td class="py-3 px-2 text-zinc-400">
                                                {% if participant.decklist %}
                                                    {{ participant.decklist.name }}
                                                {% else %}
                                                    <span class="text-zinc-600">Not submitted</span>
                                                {% endif %}
                                            </td>
                                            <td class="py-3 px-2 text-center">
                                                <span class="bg-green-900/30 text-green-300 px-2 py-1 rounded text-xs font-bold">{{ participant.wins }}</span>
                                            </td>
                                            <td class="py-3 px-2 text-center">
                                                <span class="bg-red-900/30 text-red-300 px-2 py-1 rounded text-xs font-bold">{{ participant.losses }}</span>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% else %}
                        <div class="text-center py-8">
                            <p class="text-zinc-500 font-['Space_Grotesk']">No players yet</p>
                        </div>
                    {% endif %}
                </div>
            </div>

            <!-- Sidebar -->
            <div class="lg:col-span-1">
                <!-- Invite Code -->
                <div class="bg-[rgba(18,18,18,0.7)] backdrop-blur-xl border border-[#2A2A2A] p-6 rounded-xl mb-6">
                    <h3 class="text-xs font-bold uppercase tracking-widest text-zinc-400 font-['Space_Grotesk'] mb-4">Invite Code</h3>
                    <div class="flex items-center gap-2">
                        <input 
                            type="text" 
                            value="{{ tournament.inviteCode }}" 
                            readonly
                            class="flex-1 bg-[#121212] border border-[#2A2A2A] py-2 px-3 text-lg text-[#FF8C00] font-bold font-['Space_Grotesk'] tracking-widest text-center rounded"
                        >
                        <button 
                            onclick="navigator.clipboard.writeText('{{ tournament.inviteCode }}'); alert('Code copied!');"
                            class="bg-[#FF8C00] text-black px-3 py-2 rounded hover:brightness-110 transition-all"
                        >
                            <span class="material-symbols-outlined text-sm">content_copy</span>
                        </button>
                    </div>
                </div>

                <!-- User Status -->
                {% if isCreator %}
                    <div class="bg-[#FF8C00]/10 border border-[#FF8C00]/30 p-6 rounded-xl mb-6">
                        <div class="flex items-center gap-2 mb-2">
                            <span class="material-symbols-outlined text-[#FF8C00] text-lg">admin_panel_settings</span>
                            <h3 class="text-xs font-bold uppercase tracking-widest text-[#FF8C00] font-['Space_Grotesk']">Organizer</h3>
                        </div>
                        <p class="text-xs text-[#FF8C00]/70 font-['Space_Grotesk']">You are the tournament organizer</p>
                    </div>
                {% elseif userParticipant %}
                    <div class="bg-green-900/20 border border-green-900/60 p-6 rounded-xl mb-6">
                        <div class="flex items-center gap-2 mb-2">
                            <span class="material-symbols-outlined text-green-500 text-lg">check_circle</span>
                            <h3 class="text-xs font-bold uppercase tracking-widest text-green-400 font-['Space_Grotesk']">Participant</h3>
                        </div>
                        <p class="text-xs text-green-400/70 font-['Space_Grotesk'] mb-3">You are registered for this tournament</p>
                        {% if userParticipant.decklist %}
                            <p class="text-xs text-green-300 font-['Space_Grotesk']"><strong>Decklist:</strong> {{ userParticipant.decklist.name }}</p>
                        {% else %}
                            {% if userDecklists|length > 0 %}
                                <form method="post" action="{{ path('app_tournament_submit_decklist', {id: tournament.id}) }}" class="mt-3">
                                    <select name="decklist_id" class="w-full bg-[#121212] border border-green-900/60 py-2 px-2 text-xs text-zinc-200 font-['Space_Grotesk'] rounded mb-2" required>
                                        <option value="">Select decklist...</option>
                                        {% for decklist in userDecklists %}
                                            {% if decklist.format == tournament.format %}
                                                <option value="{{ decklist.id }}">{{ decklist.name }}</option>
                                            {% endif %}
                                        {% endfor %}
                                    </select>
                                    <button type="submit" class="w-full bg-green-600/30 text-green-300 border border-green-600/60 px-3 py-2 rounded font-['Space_Grotesk'] text-xs font-bold uppercase tracking-wider hover:bg-green-600/40 transition-all">
                                        Submit Decklist
                                    </button>
                                </form>
                            {% else %}
                                <p class="text-xs text-yellow-300 font-['Space_Grotesk']">No decklists in format {{ tournament.format }}</p>
                            {% endif %}
                        {% endif %}
                    </div>
                {% else %}
                    <div class="bg-[#FF8C00]/10 border border-[#FF8C00]/30 p-6 rounded-xl mb-6">
                        <h3 class="text-xs font-bold uppercase tracking-widest text-[#FF8C00] font-['Space_Grotesk'] mb-3">Join Tournament</h3>
                        <form method="post" action="{{ path('app_tournament_join_by_code') }}">
                            <input type="hidden" name="code" value="{{ tournament.inviteCode }}">
                            <button type="submit" class="w-full bg-[#FF8C00] text-black px-3 py-2 rounded font-['Space_Grotesk'] text-xs font-bold uppercase tracking-wider hover:brightness-110 transition-all">
                                Join Now
                            </button>
                        </form>
                    </div>
                {% endif %}

                <!-- Stats -->
                <div class="bg-[rgba(18,18,18,0.7)] backdrop-blur-xl border border-[#2A2A2A] p-6 rounded-xl">
                    <h3 class="text-xs font-bold uppercase tracking-widest text-zinc-400 font-['Space_Grotesk'] mb-4">Stats</h3>
                    <div class="space-y-3">
                        <div>
                            <p class="text-xs text-zinc-500 font-['Space_Grotesk'] mb-1">Participants</p>
                            <p class="text-lg font-bold text-[#FF8C00] font-['Space_Grotesk']">{{ participants|length }}/{{ tournament.maxPlayers }}</p>
                        </div>
                        <div>
                            <p class="text-xs text-zinc-500 font-['Space_Grotesk'] mb-1">Current Round</p>
                            <p class="text-lg font-bold text-zinc-200 font-['Space_Grotesk']">{{ tournament.currentRound ?? '-' }}</p>
                        </div>
                        <div>
                            <p class="text-xs text-zinc-500 font-['Space_Grotesk'] mb-1">Status</p>
                            <p class="text-sm font-bold text-zinc-200 font-['Space_Grotesk']">{{ tournament.state|capitalize }}</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>
{% endblock %}
