{% extends 'base.html.twig' %}

{% block title %}{{ tournament.name }} - ManaHoarder{% endblock %}

{% block body %}
<main class="min-h-screen">
    <div class="max-w-[1440px] mx-auto p-8 lg:p-12">
        
        <!-- Back Button -->
        <div class="mb-6">
            <a href="{{ path('app_tournaments') }}" class="inline-flex items-center gap-2 text-zinc-300 hover:text-[#FF8C00] transition-colors text-sm font-['Space_Grotesk'] uppercase tracking-wider">
                <span class="material-symbols-outlined">arrow_back</span>
                Back to Tournaments
            </a>
        </div>

        <!-- Header -->
        <div class="mb-8 flex justify-between items-start">
            <div>
                <h1 class="font-['Space_Grotesk'] text-[40px] leading-[1.2] tracking-tighter font-bold text-[#FF8C00] mb-2 uppercase">{{ tournament.name }}</h1>
                <div class="flex items-center gap-4">
                    <span class="bg-[#FF8C00] text-black px-3 py-1 rounded text-xs font-bold uppercase tracking-wider font-['Space_Grotesk']">{{ tournament.format }}</span>
                    <span class="bg-zinc-900 border border-zinc-700 text-zinc-300 px-3 py-1 rounded text-xs font-bold uppercase tracking-wider font-['Space_Grotesk']">{{ tournament.state|upper }}</span>
                </div>
            </div>
            {% if isCreator %}
                {% if tournament.state == 'draft' %}
                    <div class="flex gap-2 flex-wrap">
                        <button onclick="document.getElementById('tournamentArtModal').classList.remove('hidden')" class="bg-zinc-900 border border-[#2A2A2A] text-zinc-300 px-4 py-3 rounded font-['Space_Grotesk'] text-xs font-bold uppercase tracking-wider hover:border-[#FF8C00]/50 transition-all flex items-center gap-2">
                            <span class="material-symbols-outlined text-sm">image</span>
                            Banner
                        </button>
                        <form method="post" action="{{ path('app_tournament_start', {id: tournament.id}) }}" class="flex">
                            <button type="submit" class="bg-[#FF8C00] text-black px-5 py-3 rounded font-['Space_Grotesk'] text-xs font-bold uppercase tracking-wider hover:brightness-110 transition-all flex items-center gap-2">
                                <span class="material-symbols-outlined text-sm">play_arrow</span>
                                Start
                            </button>
                        </form>
                        <form method="post" action="{{ path('app_tournament_delete', {id: tournament.id}) }}" onsubmit="return confirm('Are you sure? This cannot be undone.')">
                            <button type="submit" class="bg-red-600 text-white px-5 py-3 rounded font-['Space_Grotesk'] text-xs font-bold uppercase tracking-wider hover:brightness-110 transition-all flex items-center gap-2">
                                <span class="material-symbols-outlined text-sm">delete</span>
                                Delete
                            </button>
                        </form>
                    </div>
                {% else %}
                    <div class="flex gap-2">
                        <form method="post" action="{{ path('app_tournament_delete', {id: tournament.id}) }}" onsubmit="return confirm('Are you sure? This cannot be undone.')">
                            <button type="submit" class="bg-red-600 text-white px-5 py-3 rounded font-['Space_Grotesk'] text-xs font-bold uppercase tracking-wider hover:brightness-110 transition-all flex items-center gap-2">
                                <span class="material-symbols-outlined text-sm">delete</span>
                                Delete Tournament
                            </button>
                        </form>
                    </div>
                {% endif %}
            {% endif %}
        </div>

        <!-- Flash Messages -->
        {% for message in app.flashes('success') %}
            <div class="mb-6 bg-green-900/20 border border-green-900/60 text-green-100 px-6 py-4 rounded-xl flex items-center gap-3">
                <span class="material-symbols-outlined text-green-500">check_circle</span>
                <span class="font-['Space_Grotesk'] text-sm">{{ message }}</span>
            </div>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <div class="mb-6 bg-red-900/20 border border-red-900/60 text-red-100 px-6 py-4 rounded-xl flex items-center gap-3">
                <span class="material-symbols-outlined text-red-500">error</span>
                <span class="font-['Space_Grotesk'] text-sm">{{ message }}</span>
            </div>
        {% endfor %}

        <!-- Tournament Banner -->
        {% if tournament.artUrl %}
            <div id="tournamentBanner" class="mb-8 relative overflow-hidden h-48 rounded-xl border border-[#2A2A2A] group">
                <img src="{{ tournament.artUrl }}" alt="{{ tournament.name }}" class="w-full h-full object-cover">
                <div class="absolute inset-0 bg-black/30"></div>
                {% if isCreator %}
                    <button onclick="document.getElementById('tournamentArtModal').classList.remove('hidden')" class="absolute top-4 right-4 bg-black/60 backdrop-blur-sm hover:bg-black/80 text-[#FF8C00] p-2 rounded transition-all opacity-0 group-hover:opacity-100" title="Edit banner">
                        <span class="material-symbols-outlined text-sm">edit</span>
                    </button>
                {% endif %}
            </div>
        {% else %}
            <div id="tournamentBanner" class="mb-8 relative overflow-hidden h-48 rounded-xl border border-[#2A2A2A] bg-gradient-to-br from-[#FF8C00]/10 to-zinc-900 flex items-center justify-center group">
                <span class="material-symbols-outlined text-[#FF8C00] opacity-30" style="font-size: 64px;">sports_soccer</span>
                {% if isCreator %}
                    <button onclick="document.getElementById('tournamentArtModal').classList.remove('hidden')" class="absolute top-4 right-4 bg-black/60 backdrop-blur-sm hover:bg-black/80 text-[#FF8C00] p-2 rounded transition-all opacity-0 group-hover:opacity-100" title="Edit banner">
                        <span class="material-symbols-outlined text-sm">edit</span>
                    </button>
                {% endif %}
            </div>
        {% endif %}

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-10">
            <!-- Main Info -->
            <div class="lg:col-span-2">
                <!-- Tournament Details -->
                <div class="bg-[rgba(18,18,18,0.7)] backdrop-blur-xl border border-[#2A2A2A] p-6 rounded-xl mb-6">
                    <h2 class="text-sm font-bold uppercase tracking-widest text-zinc-400 font-['Space_Grotesk'] mb-4">Tournament Information</h2>
                    
                    <div class="space-y-4">
                        <div>
                            <p class="text-xs text-zinc-500 font-['Space_Grotesk'] uppercase tracking-wider mb-1">Organizer</p>
                            <div class="flex items-center gap-3">
                                {% if tournament.creator.profileArtUrl %}
                                    <img src="{{ tournament.creator.profileArtUrl }}" alt="{{ tournament.creator.nickname }}" class="w-8 h-8 rounded border border-[#2A2A2A]">
                                {% elseif tournament.creator.profilePictureFilename %}
                                    <img src="/uploads/profile-pictures/{{ tournament.creator.profilePictureFilename }}" alt="{{ tournament.creator.nickname }}" class="w-8 h-8 rounded border border-[#2A2A2A] object-cover">
                                {% else %}
                                    <div class="w-8 h-8 rounded bg-[#FF8C00]/20 border border-[#FF8C00] flex items-center justify-center text-[#FF8C00] text-xs font-bold">{{ tournament.creator.nickname|slice(0, 1)|upper }}</div>
                                {% endif %}
                                <p class="text-sm text-zinc-200 font-['Space_Grotesk']">{{ tournament.creator.nickname }}</p>
                            </div>
                        </div>
                        
                        <div>
                            <p class="text-xs text-zinc-500 font-['Space_Grotesk'] uppercase tracking-wider mb-1">Format</p>
                            <p class="text-sm text-zinc-200 font-['Space_Grotesk']">{{ tournament.format }}</p>
                        </div>
                        
                        <div>
                            <p class="text-xs text-zinc-500 font-['Space_Grotesk'] uppercase tracking-wider mb-1">Created</p>
                            <p class="text-sm text-zinc-200 font-['Space_Grotesk']">{{ tournament.createdAt|date('M d, Y H:i') }}</p>
                        </div>
                        
                        {% if tournament.startDate %}
                            <div>
                                <p class="text-xs text-zinc-500 font-['Space_Grotesk'] uppercase tracking-wider mb-1">Started</p>
                                <p class="text-sm text-zinc-200 font-['Space_Grotesk']">{{ tournament.startDate|date('M d, Y H:i') }}</p>
                            </div>
                        {% endif %}
                        
                        {% if tournament.description %}
                            <div>
                                <p class="text-xs text-zinc-500 font-['Space_Grotesk'] uppercase tracking-wider mb-1">Description</p>
                                <p class="text-sm text-zinc-200 font-['Space_Grotesk']">{{ tournament.description }}</p>
                            </div>
                        {% endif %}
                    </div>
                </div>

                <!-- Participants / Standings -->
                <div class="bg-[rgba(18,18,18,0.7)] backdrop-blur-xl border border-[#2A2A2A] p-6 rounded-xl">
                    <h2 class="text-sm font-bold uppercase tracking-widest text-zinc-400 font-['Space_Grotesk'] mb-4">Players ({{ participants|length }}/{{ tournament.maxPlayers }})</h2>
                    
                    {% if participants|length > 0 %}
                        <div class="overflow-x-auto">
                            <table class="w-full text-sm font-['Space_Grotesk']">
                                <thead>
                                    <tr class="border-b border-zinc-700">
                                        <th class="text-left text-xs text-zinc-500 uppercase tracking-wider py-2 px-2">#</th>
                                        <th class="text-left text-xs text-zinc-500 uppercase tracking-wider py-2 px-2">Player</th>
                                        <th class="text-left text-xs text-zinc-500 uppercase tracking-wider py-2 px-2">Decklist</th>
                                        <th class="text-center text-xs text-zinc-500 uppercase tracking-wider py-2 px-2">Wins</th>
                                        <th class="text-center text-xs text-zinc-500 uppercase tracking-wider py-2 px-2">Losses</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for participant in participants %}
                                        <tr class="border-b border-zinc-800 hover:bg-zinc-900/50 transition-colors">
                                            <td class="py-3 px-2 text-[#FF8C00] font-bold">{{ loop.index }}</td>
                                            <td class="py-3 px-2">
                                                <div class="flex items-center gap-2">
                                                    {% if participant.user.profileArtUrl %}
                                                        <img src="{{ participant.user.profileArtUrl }}" alt="{{ participant.user.nickname }}" class="w-6 h-6 rounded border border-[#2A2A2A]">
                                                    {% elseif participant.user.profilePictureFilename %}
                                                        <img src="/uploads/profile-pictures/{{ participant.user.profilePictureFilename }}" alt="{{ participant.user.nickname }}" class="w-6 h-6 rounded border border-[#2A2A2A] object-cover">
                                                    {% else %}
                                                        <div class="w-6 h-6 rounded bg-[#FF8C00]/20 border border-[#FF8C00] flex items-center justify-center text-[#FF8C00] text-xs font-bold">{{ participant.user.nickname|slice(0, 1)|upper }}</div>
                                                    {% endif %}
                                                    <span class="text-zinc-200">{{ participant.user.nickname }}</span>
                                                </div>
                                            </td>
                                            <td class="py-3 px-2 text-zinc-400">
                                                {% if participant.decklist %}
                                                    {{ participant.decklist.name }}
                                                {% else %}
                                                    <span class="text-zinc-600">Not submitted</span>
                                                {% endif %}
                                            </td>
                                            <td class="py-3 px-2 text-center">
                                                <span class="bg-green-900/30 text-green-300 px-2 py-1 rounded text-xs font-bold">{{ participant.wins }}</span>
                                            </td>
                                            <td class="py-3 px-2 text-center flex items-center justify-center gap-2">
                                                <span class="bg-red-900/30 text-red-300 px-2 py-1 rounded text-xs font-bold">{{ participant.losses }}</span>
                                                {% if isCreator %}
                                                    <form method="post" action="{{ path('app_tournament_remove_participant', {id: tournament.id, participantId: participant.id}) }}" class="inline" onsubmit="return confirm('Remove {{ participant.user.nickname }} from tournament?');">
                                                        <button type="submit" class="text-red-500 hover:text-red-400 transition-colors p-1" title="Remove player">
                                                            <span class="material-symbols-outlined text-sm">close</span>
                                                        </button>
                                                    </form>
                                                {% endif %}
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% else %}
                        <div class="text-center py-8">
                            <p class="text-zinc-500 font-['Space_Grotesk']">No players yet</p>
                        </div>
                    {% endif %}
                </div>
            </div>

            <!-- Sidebar -->
            <div class="lg:col-span-1">
                <!-- Invite Code -->
                <div class="bg-[rgba(18,18,18,0.7)] backdrop-blur-xl border border-[#2A2A2A] p-6 rounded-xl mb-6">
                    <h3 class="text-xs font-bold uppercase tracking-widest text-zinc-400 font-['Space_Grotesk'] mb-4">Invite Code</h3>
                    <div class="flex items-center gap-2">
                        <input 
                            type="text" 
                            value="{{ tournament.inviteCode }}" 
                            readonly
                            class="flex-1 bg-[#121212] border border-[#2A2A2A] py-2 px-3 text-lg text-[#FF8C00] font-bold font-['Space_Grotesk'] tracking-widest text-center rounded"
                        >
                        <button 
                            onclick="navigator.clipboard.writeText('{{ tournament.inviteCode }}'); alert('Code copied!');"
                            class="bg-[#FF8C00] text-black px-3 py-2 rounded hover:brightness-110 transition-all"
                        >
                            <span class="material-symbols-outlined text-sm">content_copy</span>
                        </button>
                    </div>
                </div>

                <!-- User Status -->
                {% if isCreator %}
                    <div class="bg-[#FF8C00]/10 border border-[#FF8C00]/30 p-6 rounded-xl mb-6">
                        <div class="flex items-center gap-2 mb-2">
                            <span class="material-symbols-outlined text-[#FF8C00] text-lg">admin_panel_settings</span>
                            <h3 class="text-xs font-bold uppercase tracking-widest text-[#FF8C00] font-['Space_Grotesk']">Organizer</h3>
                        </div>
                        <p class="text-xs text-[#FF8C00]/70 font-['Space_Grotesk']">You are the tournament organizer</p>
                    </div>
                {% elseif userParticipant %}
                    <div class="bg-green-900/20 border border-green-900/60 p-6 rounded-xl mb-6">
                        <div class="flex items-center gap-2 mb-2">
                            <span class="material-symbols-outlined text-green-500 text-lg">check_circle</span>
                            <h3 class="text-xs font-bold uppercase tracking-widest text-green-400 font-['Space_Grotesk']">Participant</h3>
                        </div>
                        <p class="text-xs text-green-400/70 font-['Space_Grotesk'] mb-3">You are registered for this tournament</p>
                        {% if userParticipant.decklist %}
                            <p class="text-xs text-green-300 font-['Space_Grotesk']"><strong>Decklist:</strong> {{ userParticipant.decklist.name }}</p>
                        {% else %}
                            {% if userDecklists|length > 0 %}
                                <form method="post" action="{{ path('app_tournament_submit_decklist', {id: tournament.id}) }}" class="mt-3">
                                    <select name="decklist_id" class="w-full bg-[#121212] border border-green-900/60 py-2 px-2 text-xs text-zinc-200 font-['Space_Grotesk'] rounded mb-2" required>
                                        <option value="">Select decklist...</option>
                                        {% for decklist in userDecklists %}
                                            {% if decklist.format == tournament.format %}
                                                <option value="{{ decklist.id }}">{{ decklist.name }}</option>
                                            {% endif %}
                                        {% endfor %}
                                    </select>
                                    <button type="submit" class="w-full bg-green-600/30 text-green-300 border border-green-600/60 px-3 py-2 rounded font-['Space_Grotesk'] text-xs font-bold uppercase tracking-wider hover:bg-green-600/40 transition-all">
                                        Submit Decklist
                                    </button>
                                </form>
                            {% else %}
                                <p class="text-xs text-yellow-300 font-['Space_Grotesk']">No decklists in format {{ tournament.format }}</p>
                            {% endif %}
                        {% endif %}
                    </div>
                {% else %}
                    <div class="bg-[#FF8C00]/10 border border-[#FF8C00]/30 p-6 rounded-xl mb-6">
                        <h3 class="text-xs font-bold uppercase tracking-widest text-[#FF8C00] font-['Space_Grotesk'] mb-3">Join Tournament</h3>
                        {% if userDecklists|length > 0 %}
                            <form method="post" action="{{ path('app_tournament_join_by_code') }}" class="space-y-3">
                                <input type="hidden" name="code" value="{{ tournament.inviteCode }}">
                                <div>
                                    <label class="block text-xs text-[#FF8C00] font-['Space_Grotesk'] uppercase tracking-wider mb-2">Select Deck</label>
                                    <select name="decklist_id" class="w-full bg-[#121212] border border-[#FF8C00]/30 py-2 px-3 text-xs text-zinc-200 font-['Space_Grotesk'] rounded text-white" required>
                                        <option value="">Choose a deck...</option>
                                        {% for decklist in userDecklists %}
                                            <option value="{{ decklist.id }}">{{ decklist.name }}</option>
                                        {% endfor %}
                                    </select>
                                </div>
                                <button type="submit" class="w-full bg-[#FF8C00] text-black px-3 py-2 rounded font-['Space_Grotesk'] text-xs font-bold uppercase tracking-wider hover:brightness-110 transition-all">
                                    Join Now
                                </button>
                            </form>
                        {% else %}
                            <div class="bg-red-900/20 border border-red-900/60 p-3 rounded">
                                <p class="text-xs text-red-300 font-['Space_Grotesk']">You don't have any decks in {{ tournament.format }} format. Create a deck first to join this tournament.</p>
                                <a href="{{ path('app_deck_create') }}" class="inline-block mt-3 bg-[#FF8C00] text-black px-3 py-2 rounded font-['Space_Grotesk'] text-xs font-bold uppercase tracking-wider hover:brightness-110 transition-all">
                                    Create Deck
                                </a>
                            </div>
                        {% endif %}
                    </div>
                {% endif %}

                <!-- Stats -->
                <div class="bg-[rgba(18,18,18,0.7)] backdrop-blur-xl border border-[#2A2A2A] p-6 rounded-xl">
                    <h3 class="text-xs font-bold uppercase tracking-widest text-zinc-400 font-['Space_Grotesk'] mb-4">Stats</h3>
                    <div class="space-y-3">
                        <div>
                            <p class="text-xs text-zinc-500 font-['Space_Grotesk'] mb-1">Participants</p>
                            <p class="text-lg font-bold text-[#FF8C00] font-['Space_Grotesk']">{{ participants|length }}/{{ tournament.maxPlayers }}</p>
                        </div>
                        <div>
                            <p class="text-xs text-zinc-500 font-['Space_Grotesk'] mb-1">Current Round</p>
                            <p class="text-lg font-bold text-zinc-200 font-['Space_Grotesk']">{{ tournament.currentRound ?? '-' }}</p>
                        </div>
                        <div>
                            <p class="text-xs text-zinc-500 font-['Space_Grotesk'] mb-1">Status</p>
                            <p class="text-sm font-bold text-zinc-200 font-['Space_Grotesk']">{{ tournament.state|capitalize }}</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<!-- Tournament Art Selection Modal -->
<div id="tournamentArtModal" class="hidden fixed inset-0 bg-black/80 backdrop-blur-sm z-50 flex items-center justify-center p-4">
    <div class="bg-[#121212] border border-[#2A2A2A] rounded-xl max-w-2xl w-full p-6 max-h-[90vh] overflow-y-auto">
        <div class="flex items-center justify-between mb-6">
            <h2 class="font-['Space_Grotesk'] text-xl font-bold text-white uppercase tracking-tight">Tournament Banner</h2>
            <button onclick="document.getElementById('tournamentArtModal').classList.add('hidden')" class="text-zinc-500 hover:text-white transition-colors">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>

        <!-- Action Buttons -->
        <div class="flex gap-2 mb-6">
            <button onclick="clearTournamentBanner()" class="flex-1 bg-zinc-900 border border-[#2A2A2A] text-zinc-300 px-4 py-2 rounded font-['Space_Grotesk'] text-xs font-bold uppercase tracking-wider hover:border-red-600/50 transition-all flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-sm">close</span>
                Remove Banner
            </button>
        </div>

        <!-- Search Input -->
        <div class="mb-4">
            <input 
                type="text" 
                id="tournamentArtSearch"
                placeholder="Search for cards (e.g., 'Black Lotus', 'Mana Drain')" 
                class="w-full bg-[#1A1B1E] border border-[#2A2A2A] py-2.5 px-3 text-sm text-zinc-200 placeholder-zinc-600 font-['Space_Grotesk'] tracking-wide focus:border-[#FF8C00] outline-none rounded"
            >
            <p class="mt-1 text-xs text-zinc-500">Search for any Magic card to use its art as tournament banner</p>
        </div>

        <!-- Search Results -->
        <div id="tournamentArtResults" class="grid grid-cols-3 sm:grid-cols-4 gap-3 max-h-96 overflow-y-auto">
            <p class="col-span-full text-center text-sm text-zinc-500 py-8">Enter a card name to search</p>
        </div>
    </div>
</div>

<script>
    // Search for tournament art
    const searchInput = document.getElementById('tournamentArtSearch');
    if (searchInput) {
        let searchTimeout;
        searchInput.addEventListener('input', function() {
            clearTimeout(searchTimeout);
            
            const query = this.value.trim();
            if (query.length < 2) {
                document.getElementById('tournamentArtResults').innerHTML = '<p class="col-span-full text-center text-sm text-zinc-500 py-8">Enter a card name to search</p>';
                return;
            }
            
            searchTimeout = setTimeout(() => {
                fetch(`{{ path('app_tournament_search_art', {id: tournament.id}) }}?q=${encodeURIComponent(query)}`)
                    .then(response => response.json())
                    .then(data => {
                        const resultsDiv = document.getElementById('tournamentArtResults');
                        
                        if (data.data.length === 0) {
                            resultsDiv.innerHTML = '<p class="col-span-full text-center text-sm text-zinc-500 py-8">No cards found with art</p>';
                            return;
                        }
                        
                        resultsDiv.innerHTML = data.data.map(card => `
                            <button 
                                type="button"
                                onclick="selectTournamentArt('${card.artCropUrl}', '${card.name}')"
                                class="group relative overflow-hidden rounded border-2 border-[#2A2A2A] hover:border-[#FF8C00] transition-all"
                                title="${card.name}"
                            >
                                <img src="${card.artCropUrl}" alt="${card.name}" class="w-full h-auto aspect-[3/4] object-cover group-hover:opacity-80 transition-opacity">
                                <div class="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                                    <span class="material-symbols-outlined text-[#FF8C00] text-xl">check_circle</span>
                                </div>
                                <div class="absolute bottom-0 left-0 right-0 bg-black/80 p-1 opacity-0 group-hover:opacity-100 transition-opacity">
                                    <p class="text-xs text-white truncate">${card.name}</p>
                                </div>
                            </button>
                        `).join('');
                    })
                    .catch(error => {
                        console.error('Search error:', error);
                        document.getElementById('tournamentArtResults').innerHTML = '<p class="col-span-full text-center text-sm text-red-500 py-8">Error searching cards</p>';
                    });
            }, 300);
        });
    }

    // Select tournament art
    function selectTournamentArt(artUrl, cardName) {
        const modal = document.getElementById('tournamentArtModal');
        const banner = document.getElementById('tournamentBanner');
        
        // Show loading state
        const selectedButton = event.target.closest('button');
        selectedButton.classList.add('opacity-50', 'cursor-wait');
        
        fetch('{{ path('app_tournament_update_art', {id: tournament.id}) }}', {
            method: 'POST',
            headers: {
                'X-Requested-With': 'XMLHttpRequest',
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({
                artUrl: artUrl,
                cardName: cardName,
            }),
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                // Update banner
                if (!banner) {
                    // Create new banner if it doesn't exist
                    const header = document.querySelector('main > div > div:nth-child(3)');
                    const newBanner = document.createElement('div');
                    newBanner.id = 'tournamentBanner';
                    newBanner.className = 'mb-8 relative overflow-hidden h-48 rounded-xl border border-[#2A2A2A]';
                    newBanner.innerHTML = `<img src="${artUrl}" alt="${cardName}" class="w-full h-full object-cover"><div class="absolute inset-0 bg-black/30"></div>`;
                    header.insertBefore(newBanner, header.firstChild);
                } else {
                    const img = banner.querySelector('img');
                    img.src = artUrl;
                }
                
                // Show success message
                const successMsg = document.createElement('div');
                successMsg.className = 'fixed top-4 right-4 bg-green-900/20 border border-green-900/60 text-green-100 px-6 py-4 rounded-xl flex items-center gap-3 z-50';
                successMsg.innerHTML = `<span class="material-symbols-outlined text-green-500">check_circle</span><span class="font-['Space_Grotesk'] text-sm">Tournament banner updated with ${cardName}</span>`;
                document.body.appendChild(successMsg);
                
                setTimeout(() => successMsg.remove(), 3000);
                setTimeout(() => modal.classList.add('hidden'), 500);
            } else {
                const errorMsg = document.createElement('div');
                errorMsg.className = 'fixed top-4 right-4 bg-red-900/20 border border-red-900/60 text-red-100 px-6 py-4 rounded-xl flex items-center gap-3 z-50';
                errorMsg.innerHTML = `<span class="material-symbols-outlined text-red-500">error</span><span class="font-['Space_Grotesk'] text-sm">Failed to update tournament banner</span>`;
                document.body.appendChild(errorMsg);
                setTimeout(() => errorMsg.remove(), 3000);
                selectedButton.classList.remove('opacity-50', 'cursor-wait');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            const errorMsg = document.createElement('div');
            errorMsg.className = 'fixed top-4 right-4 bg-red-900/20 border border-red-900/60 text-red-100 px-6 py-4 rounded-xl flex items-center gap-3 z-50';
            errorMsg.innerHTML = `<span class="material-symbols-outlined text-red-500">error</span><span class="font-['Space_Grotesk'] text-sm">Error updating tournament banner</span>`;
            document.body.appendChild(errorMsg);
            setTimeout(() => errorMsg.remove(), 3000);
            selectedButton.classList.remove('opacity-50', 'cursor-wait');
        });
    }

    // Clear tournament banner
    function clearTournamentBanner() {
        const modal = document.getElementById('tournamentArtModal');
        const banner = document.getElementById('tournamentBanner');
        
        if (confirm('Remove the tournament banner?')) {
            fetch('{{ path('app_tournament_clear_art', {id: tournament.id}) }}', {
                method: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'Content-Type': 'application/json',
                },
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    if (banner) {
                        // Replace with placeholder
                        banner.innerHTML = '<div class="w-full h-full bg-gradient-to-br from-[#FF8C00]/10 to-zinc-900 flex items-center justify-center"><span class="material-symbols-outlined text-[#FF8C00] opacity-30" style="font-size: 64px;">sports_soccer</span></div>';
                    }
                    
                    const successMsg = document.createElement('div');
                    successMsg.className = 'fixed top-4 right-4 bg-green-900/20 border border-green-900/60 text-green-100 px-6 py-4 rounded-xl flex items-center gap-3 z-50';
                    successMsg.innerHTML = `<span class="material-symbols-outlined text-green-500">check_circle</span><span class="font-['Space_Grotesk'] text-sm">Tournament banner removed</span>`;
                    document.body.appendChild(successMsg);
                    
                    setTimeout(() => successMsg.remove(), 3000);
                    setTimeout(() => modal.classList.add('hidden'), 500);
                } else {
                    const errorMsg = document.createElement('div');
                    errorMsg.className = 'fixed top-4 right-4 bg-red-900/20 border border-red-900/60 text-red-100 px-6 py-4 rounded-xl flex items-center gap-3 z-50';
                    errorMsg.innerHTML = `<span class="material-symbols-outlined text-red-500">error</span><span class="font-['Space_Grotesk'] text-sm">Failed to remove banner</span>`;
                    document.body.appendChild(errorMsg);
                    setTimeout(() => errorMsg.remove(), 3000);
                }
            })
            .catch(error => {
                console.error('Error:', error);
                const errorMsg = document.createElement('div');
                errorMsg.className = 'fixed top-4 right-4 bg-red-900/20 border border-red-900/60 text-red-100 px-6 py-4 rounded-xl flex items-center gap-3 z-50';
                errorMsg.innerHTML = `<span class="material-symbols-outlined text-red-500">error</span><span class="font-['Space_Grotesk'] text-sm">Error removing banner</span>`;
                document.body.appendChild(errorMsg);
                setTimeout(() => errorMsg.remove(), 3000);
            });
        }
    }
</script>
{% endblock %}
