{% extends 'base.html.twig' %}

{% block title %}{{ card.name }} - ManaHoarder{% endblock %}

{% block body %}
<main class="min-h-screen">
    <div class="max-w-[1440px] mx-auto p-8 lg:p-12">
        
        <!-- Back Button -->
        <div class="mb-6">
            <a href="javascript:history.back()" class="inline-flex items-center gap-2 text-zinc-300 hover:text-[#FF8C00] transition-colors text-sm font-['Space_Grotesk'] uppercase tracking-wider">
                <span class="material-symbols-outlined">arrow_back</span>
                Back to Search
            </a>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            
            <!-- Left Column: Card Image(s), Prices, and Actions -->
            <div class="space-y-4">
                {% if card.images|length > 0 %}
                    <div class="bg-[#1A1B1E] border border-[#2A2A2A] rounded-xl overflow-hidden relative" id="cardImageContainer">
                        {% if card.images|length > 1 %}
                            <!-- Flip button for double-faced cards -->
                            <button onclick="flipCard()" class="absolute bottom-4 left-1/2 -translate-x-1/2 z-10 bg-[#FF8C00] hover:bg-[#ff9d26] text-black w-14 h-14 rounded-full transition-all backdrop-blur-sm border-2 border-black/30 hover:border-black/50 shadow-xl flex items-center justify-center" title="Flip card">
                                <span class="material-symbols-outlined text-3xl font-bold">sync</span>
                            </button>
                        {% elseif card.layout == 'flip' %}
                            <!-- Rotate button for flip cards (180° rotation) -->
                            <button onclick="rotateFlipCard()" class="absolute bottom-4 left-1/2 -translate-x-1/2 z-10 bg-[#FF8C00] hover:bg-[#ff9d26] text-black w-14 h-14 rounded-full transition-all backdrop-blur-sm border-2 border-black/30 hover:border-black/50 shadow-xl flex items-center justify-center" title="Rotate card 180°">
                                <span class="material-symbols-outlined text-3xl font-bold">rotate_left</span>
                            </button>
                        {% endif %}
                        
                        {% for image in card.images %}
                            <div class="card-face {{ loop.index0 > 0 ? 'hidden' : '' }}" data-face-index="{{ loop.index0 }}">
                                {% if image.large %}
                                    <img src="{{ image.large }}" alt="{{ image.name ?? card.name }}" class="w-full h-auto rounded-[1.5rem]">
                                {% else %}
                                    <div class="aspect-[5/7] flex items-center justify-center bg-zinc-900">
                                        <span class="material-symbols-outlined text-8xl text-zinc-700">style</span>
                                    </div>
                                {% endif %}
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}

                <!-- Prices -->
                {% if card.prices.usd or card.prices.usd_foil or card.prices.eur %}
                    <div class="bg-[rgba(18,18,18,0.7)] backdrop-blur-xl border border-[#2A2A2A] p-4 rounded-xl">
                        <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-400 font-['Space_Grotesk'] mb-3">Market Prices</h2>
                        <div class="grid grid-cols-2 gap-3">
                            {% if card.prices.usd %}
                                <div>
                                    <span class="text-xs text-zinc-400 font-['Space_Grotesk']">USD</span>
                                    <p class="text-base font-bold text-[#FF8C00] font-['Space_Grotesk']">${{ card.prices.usd }}</p>
                                </div>
                            {% endif %}
                            {% if card.prices.usd_foil %}
                                <div>
                                    <span class="text-xs text-zinc-400 font-['Space_Grotesk']">USD Foil</span>
                                    <p class="text-base font-bold text-[#FF8C00] font-['Space_Grotesk']">${{ card.prices.usd_foil }}</p>
                                </div>
                            {% endif %}
                            {% if card.prices.eur %}
                                <div>
                                    <span class="text-xs text-zinc-400 font-['Space_Grotesk']">EUR</span>
                                    <p class="text-base font-bold text-[#FF8C00] font-['Space_Grotesk']">€{{ card.prices.eur }}</p>
                                </div>
                            {% endif %}
                            {% if card.prices.eur_foil %}
                                <div>
                                    <span class="text-xs text-zinc-400 font-['Space_Grotesk']">EUR Foil</span>
                                    <p class="text-base font-bold text-[#FF8C00] font-['Space_Grotesk']">€{{ card.prices.eur_foil }}</p>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                {% endif %}

                <!-- Action Buttons -->
                <div class="space-y-2">
                    <button class="w-full bg-[#FF8C00] text-black px-4 py-3 rounded font-['Space_Grotesk'] text-sm font-bold uppercase tracking-wider hover:brightness-110 transition-all flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined text-base">add</span>
                        Add to Deck
                    </button>
                    <button class="w-full bg-zinc-900 border border-[#2A2A2A] text-zinc-300 px-4 py-3 rounded font-['Space_Grotesk'] text-sm font-bold uppercase tracking-wider hover:border-[#FF8C00]/50 transition-all flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined text-base">bookmark</span>
                        Add to Collection
                    </button>
                </div>
            </div>

            <!-- Right Column: Card Details (Single Column) -->
            <div class="lg:col-span-2 space-y-3">
                
                <!-- Card Name and Mana Cost -->
                <div class="bg-[rgba(18,18,18,0.7)] backdrop-blur-xl border border-[#2A2A2A] p-4 rounded-xl" id="cardHeader">
                    <div class="flex items-start justify-between gap-4 mb-3">
                        <h1 class="font-['Space_Grotesk'] text-2xl font-bold text-white" id="cardName">{{ card.name }}</h1>
                        <div class="text-lg text-zinc-300 font-['Space_Grotesk'] whitespace-nowrap flex items-center gap-1" id="cardManaCost">
                            {% if card.mana_cost %}{{ card.mana_cost|mana_symbols|raw }}{% endif %}
                        </div>
                    </div>
                    
                    <div class="flex items-center gap-3 mb-3">
                        <span class="bg-[#FF8C00] text-black px-2 py-1 rounded-full text-xs font-bold uppercase tracking-wider font-['Space_Grotesk']">
                            {{ card.rarity }}
                        </span>
                        <div class="flex gap-1" id="cardColors">
                            {% if card.colors|length > 0 %}
                                {% for color in card.colors %}
                                    <div class="w-4 h-4 rounded-full border border-white/30 {{ color == 'W' ? 'bg-yellow-50' : color == 'U' ? 'bg-blue-600' : color == 'B' ? 'bg-purple-900' : color == 'R' ? 'bg-red-600' : 'bg-green-600' }}"></div>
                                {% endfor %}
                            {% endif %}
                        </div>
                        <span class="ml-auto text-lg font-bold text-white font-['Space_Grotesk']" id="cardStats">
                            {% if card.power %}{{ card.power }}/{{ card.toughness }}{% endif %}
                            {% if card.loyalty %}Loyalty: {{ card.loyalty }}{% endif %}
                        </span>
                    </div>

                    <div id="cardTypeLineContainer" class="text-sm font-['Space_Grotesk'] italic">
                        <!-- Type line will be rendered here with clickable types -->
                    </div>
                </div>

                <!-- Oracle Text -->
                <div class="bg-[rgba(18,18,18,0.7)] backdrop-blur-xl border border-[#2A2A2A] p-4 rounded-xl" id="oracleTextContainer" {% if not card.oracle_text %}style="display:none;"{% endif %}>
                    <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-400 font-['Space_Grotesk'] mb-2">Rules Text</h2>
                    <div class="text-sm text-zinc-200 font-['Space_Grotesk'] leading-relaxed" id="cardOracleText">{{ card.oracle_text|nl2br|mana_symbols|raw }}</div>
                </div>

                <!-- Flavor Text -->
                <div class="bg-[rgba(18,18,18,0.7)] backdrop-blur-xl border border-[#2A2A2A] p-4 rounded-xl" id="flavorTextContainer" {% if not card.flavor_text %}style="display:none;"{% endif %}>
                    <div class="text-sm text-zinc-400 font-['Space_Grotesk'] italic leading-relaxed" id="cardFlavorText">{{ card.flavor_text }}</div>
                </div>

                <!-- Keywords -->
                {% if card.keywords|length > 0 %}
                    <div class="bg-[rgba(18,18,18,0.7)] backdrop-blur-xl border border-[#2A2A2A] p-4 rounded-xl">
                        <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-400 font-['Space_Grotesk'] mb-2">Keywords</h2>
                        <div class="flex flex-wrap gap-2">
                            {% for keyword in card.keywords %}
                                <span class="bg-zinc-900 border border-zinc-700 px-2 py-1 rounded-full text-xs text-zinc-300 font-['Space_Grotesk']">{{ keyword }}</span>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}

                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                    <!-- Card Information -->
                    <div class="bg-[rgba(18,18,18,0.7)] backdrop-blur-xl border border-[#2A2A2A] p-4 rounded-xl">
                        <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-400 font-['Space_Grotesk'] mb-3">Card Information</h2>
                        <div class="space-y-2">
                            <div class="flex justify-between items-center gap-2">
                                <span class="text-xs text-zinc-400 font-['Space_Grotesk']">Set</span>
                                <span class="text-xs text-zinc-200 font-['Space_Grotesk'] font-semibold text-right">{{ card.set_name }} ({{ card.set|upper }})</span>
                            </div>
                            <div class="flex justify-between items-center gap-2">
                                <span class="text-xs text-zinc-400 font-['Space_Grotesk']">Number</span>
                                <span class="text-xs text-zinc-200 font-['Space_Grotesk'] font-semibold">{{ card.collector_number }}</span>
                            </div>
                            <div class="flex justify-between items-center gap-2">
                                <span class="text-xs text-zinc-400 font-['Space_Grotesk']">Artist</span>
                                <span class="text-xs text-zinc-200 font-['Space_Grotesk'] font-semibold text-right">{{ card.artist }}</span>
                            </div>
                            {% if card.cmc %}
                                <div class="flex justify-between items-center gap-2">
                                    <span class="text-xs text-zinc-400 font-['Space_Grotesk']">CMC</span>
                                    <span class="text-xs text-zinc-200 font-['Space_Grotesk'] font-semibold">{{ card.cmc }}</span>
                                </div>
                            {% endif %}
                        </div>
                    </div>

                    <!-- Format Legality -->
                    {% if card.legalities %}
                        <div class="bg-[rgba(18,18,18,0.7)] backdrop-blur-xl border border-[#2A2A2A] p-4 rounded-xl">
                            <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-400 font-['Space_Grotesk'] mb-3">Format Legality</h2>
                            <div class="space-y-2">
                                {% for format, legality in card.legalities %}
                                    {% if legality != 'not_legal' and format in ['standard', 'modern', 'commander', 'legacy', 'vintage', 'pioneer'] %}
                                        <div class="flex items-center justify-between bg-zinc-900/50 border border-zinc-800 px-2 py-1.5 rounded">
                                            <span class="text-xs text-zinc-300 font-['Space_Grotesk'] capitalize">{{ format|replace({'_': ' '}) }}</span>
                                            <span class="text-xs font-bold font-['Space_Grotesk'] {{ legality == 'legal' ? 'text-green-500' : legality == 'banned' ? 'text-red-500' : 'text-yellow-500' }}">
                                                {{ legality|upper }}
                                            </span>
                                        </div>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}
                </div>

            </div>

        </div>
    </div>
</main>

<script>
    // Card flip functionality for double-faced cards
    const cardData = {{ card|json_encode|raw }};
    let currentFaceIndex = 0;
    let currentRotation = 0; // Track rotation for flip cards

    // Known card types for parsing
    const SUPERTYPES = ['legendary', 'world', 'snow', 'basic', 'ongoing', 'elite', 'host'];
    const CARD_TYPES = ['artifact', 'creature', 'enchantment', 'land', 'planeswalker', 'instant', 'sorcery', 'tribal', 'battle', 'kindred', 'conspiracy', 'phenomenon', 'plane', 'scheme', 'vanguard'];

    // Function to replace mana symbols with SVG images
    function replaceManaSymbols(text) {
        if (!text) return '';
        return text.replace(/\{([^}]+)\}/g, function(match, symbol) {
            const symbolName = symbol.replace(/\//g, '').toUpperCase();
            return `<img src="https://svgs.scryfall.io/card-symbols/${symbolName}.svg" class="mana-symbol" alt="${match}" title="${match}">`;
        });
    }

    // Initialize type line on page load
    document.addEventListener('DOMContentLoaded', function() {
        renderTypeLine(cardData.type_line);
    });

    function renderTypeLine(typeLine) {
        if (!typeLine) return;
        
        const container = document.getElementById('cardTypeLineContainer');
        if (!container) return;

        // Split by em-dash or regular dash to separate main types from subtypes
        const parts = typeLine.split(/\s+[—\-]\s+/);
        const mainTypes = parts[0] || '';
        const subTypes = parts[1] || '';

        let html = '';

        // Parse main types (supertypes + card types)
        if (mainTypes) {
            const words = mainTypes.split(/\s+/);
            words.forEach((word, index) => {
                const lowerWord = word.toLowerCase();
                const isSupertype = SUPERTYPES.includes(lowerWord);
                const isCardType = CARD_TYPES.includes(lowerWord);

                if (isSupertype || isCardType) {
                    html += `<a href="{{ path('app_card_search') }}?q=t:${encodeURIComponent(lowerWord)}" class="text-zinc-300 hover:text-[#FF8C00] hover:underline transition-colors">${word}</a>`;
                } else {
                    html += `<span class="text-zinc-300">${word}</span>`;
                }

                if (index < words.length - 1) {
                    html += ' ';
                }
            });
        }

        // Add separator
        if (subTypes) {
            html += ' <span class="text-zinc-500">—</span> ';

            // Parse subtypes
            const subTypeWords = subTypes.split(/\s+/);
            subTypeWords.forEach((word, index) => {
                html += `<a href="{{ path('app_card_search') }}?q=t:${encodeURIComponent(word.toLowerCase())}" class="text-zinc-300 hover:text-[#FF8C00] hover:underline transition-colors">${word}</a>`;
                
                if (index < subTypeWords.length - 1) {
                    html += ' ';
                }
            });
        }

        container.innerHTML = html;
    }

    function flipCard() {
        const faces = document.querySelectorAll('.card-face');
        if (faces.length <= 1) return;

        const currentFace = faces[currentFaceIndex];
        const nextFaceIndex = (currentFaceIndex + 1) % faces.length;
        const nextFace = faces[nextFaceIndex];

        // Add flipping animation classes
        currentFace.classList.add('flipping-out');
        
        // Wait for half the animation, then switch faces
        setTimeout(() => {
            currentFace.classList.add('hidden');
            currentFace.classList.remove('flipping-out');
            
            nextFace.classList.remove('hidden');
            nextFace.classList.add('flipping-in');
            
            // Update current face index
            currentFaceIndex = nextFaceIndex;
            
            // Remove animation class after animation completes
            setTimeout(() => {
                nextFace.classList.remove('flipping-in');
            }, 600);
            
            // Update card information if card_faces data exists
            if (cardData.card_faces && cardData.card_faces[currentFaceIndex]) {
                updateCardInfo(cardData.card_faces[currentFaceIndex]);
            }
        }, 300);
    }

    // Rotate function for flip cards (180° rotation on same face)
    function rotateFlipCard() {
        const cardFace = document.querySelector('.card-face');
        if (!cardFace) return;

        // Toggle rotation by 180 degrees
        currentRotation = (currentRotation + 180) % 360;
        
        cardFace.classList.add('rotating');
        cardFace.style.transform = `rotate(${currentRotation}deg)`;
        
        // Remove the rotating class after animation completes
        setTimeout(() => {
            cardFace.classList.remove('rotating');
        }, 800);
    }

    function updateCardInfo(faceData) {
        // Update card name
        const cardName = document.getElementById('cardName');
        if (cardName && faceData.name) {
            cardName.textContent = faceData.name;
        }

        // Update mana cost
        const cardManaCost = document.getElementById('cardManaCost');
        if (cardManaCost) {
            cardManaCost.innerHTML = replaceManaSymbols(faceData.mana_cost || '');
        }

        // Update type line with clickable types
        if (faceData.type_line) {
            renderTypeLine(faceData.type_line);
        }

        // Update oracle text
        const cardOracleText = document.getElementById('cardOracleText');
        const oracleTextContainer = document.getElementById('oracleTextContainer');
        if (cardOracleText && oracleTextContainer) {
            if (faceData.oracle_text) {
                // Replace line breaks and mana symbols
                const textWithBreaks = faceData.oracle_text.replace(/\n/g, '<br>');
                cardOracleText.innerHTML = replaceManaSymbols(textWithBreaks);
                oracleTextContainer.style.display = 'block';
            } else {
                oracleTextContainer.style.display = 'none';
            }
        }

        // Update flavor text
        const cardFlavorText = document.getElementById('cardFlavorText');
        const flavorTextContainer = document.getElementById('flavorTextContainer');
        if (cardFlavorText && flavorTextContainer) {
            if (faceData.flavor_text) {
                cardFlavorText.textContent = faceData.flavor_text;
                flavorTextContainer.style.display = 'block';
            } else {
                flavorTextContainer.style.display = 'none';
            }
        }

        // Update colors
        const cardColors = document.getElementById('cardColors');
        if (cardColors && faceData.colors) {
            cardColors.innerHTML = '';
            faceData.colors.forEach(color => {
                const colorDiv = document.createElement('div');
                colorDiv.className = 'w-4 h-4 rounded-full border border-white/30';
                
                if (color === 'W') colorDiv.classList.add('bg-yellow-50');
                else if (color === 'U') colorDiv.classList.add('bg-blue-600');
                else if (color === 'B') colorDiv.classList.add('bg-purple-900');
                else if (color === 'R') colorDiv.classList.add('bg-red-600');
                else if (color === 'G') colorDiv.classList.add('bg-green-600');
                
                cardColors.appendChild(colorDiv);
            });
        }

        // Update power/toughness or loyalty
        const cardStats = document.getElementById('cardStats');
        if (cardStats) {
            if (faceData.power && faceData.toughness) {
                cardStats.textContent = `${faceData.power}/${faceData.toughness}`;
            } else if (faceData.loyalty) {
                cardStats.textContent = `Loyalty: ${faceData.loyalty}`;
            } else {
                cardStats.textContent = '';
            }
        }
    }
</script>
{% endblock %}
