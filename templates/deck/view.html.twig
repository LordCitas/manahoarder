{% extends 'base.html.twig' %}

{% block title %}{{ deck.name }} - ManaHoarder{% endblock %}

{% block body %}
<style>
    #searchResults::-webkit-scrollbar {
        width: 8px;
    }
    #searchResults::-webkit-scrollbar-track {
        background: #121212;
    }
    #searchResults::-webkit-scrollbar-thumb {
        background: #FF8C00;
        border-radius: 4px;
    }
    #searchResults::-webkit-scrollbar-thumb:hover {
        background: #ff9d26;
    }
    #searchResults {
        scrollbar-color: #FF8C00 #121212;
        scrollbar-width: thin;
    }
    #deckCardsList::-webkit-scrollbar {
        width: 8px;
    }
    #deckCardsList::-webkit-scrollbar-track {
        background: #121212;
    }
    #deckCardsList::-webkit-scrollbar-thumb {
        background: #FF8C00;
        border-radius: 4px;
    }
    #deckCardsList::-webkit-scrollbar-thumb:hover {
        background: #ff9d26;
    }
    #deckCardsList {
        scrollbar-color: #FF8C00 #121212;
        scrollbar-width: thin;
    }
</style>
<main class="min-h-screen">
    <div class="max-w-[1600px] mx-auto p-8 lg:p-12">
        <!-- Header with Back Button -->
        <div class="mb-8 flex items-center gap-4">
            <a href="{{ path('app_decks') }}" class="bg-zinc-900 border border-[#2A2A2A] text-zinc-300 px-4 py-2 rounded hover:border-[#FF8C00]/50 transition-all flex items-center gap-2">
                <span class="material-symbols-outlined text-sm">arrow_back</span>
                Back to Decks
            </a>
        </div>

        <!-- Header Section -->
        <div class="mb-10">
            <h1 class="font-['Space_Grotesk'] text-[40px] leading-[1.2] tracking-tighter font-bold text-[#FF8C00] mb-2 uppercase">{{ deck.name }}</h1>
            <p class="text-zinc-300 text-lg">Edit your deck and manage cards</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Left Panel - Search -->
            <div class="lg:col-span-2">
                <!-- Card Search -->
                <div class="bg-[rgba(18,18,18,0.7)] backdrop-blur-xl border border-[#2A2A2A] rounded-xl p-6 mb-6">
                    <label class="block text-xs font-bold uppercase tracking-widest text-zinc-400 font-['Space_Grotesk'] mb-3">Search Cards</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-zinc-500">search</span>
                        <input 
                            type="text" 
                            id="cardSearch"
                            placeholder="Search by card name..." 
                            class="w-full bg-[#121212] border border-[#2A2A2A] py-4 pl-12 pr-3 text-base text-zinc-200 placeholder-zinc-600 font-['Space_Grotesk'] tracking-wide focus:border-[#FF8C00] outline-none rounded"
                        >
                    </div>
                </div>

                <!-- Columns Selector -->
                <div class="flex items-center gap-3 mb-4">
                    <label class="text-xs font-bold uppercase tracking-widest text-zinc-400 font-['Space_Grotesk']">Cards per row:</label>
                    <select id="columnsSelector" class="bg-[#121212] border border-[#2A2A2A] py-2 px-3 text-sm text-zinc-200 font-['Space_Grotesk'] focus:border-[#FF8C00] outline-none rounded">
                        <option value="2">2</option>
                        <option value="3" selected>3</option>
                        <option value="4">4</option>
                        <option value="5">5</option>
                        <option value="6">6</option>
                    </select>
                    <div class="ml-auto flex items-center gap-2">
                        <label class="text-xs font-bold uppercase tracking-widest text-zinc-400 font-['Space_Grotesk']">Add to:</label>
                        <button id="mainDeckToggle" class="bg-[#FF8C00] text-black px-4 py-2 rounded font-['Space_Grotesk'] text-xs font-bold uppercase tracking-wider hover:brightness-110 transition-all">Main Deck</button>
                        <button id="sideboardToggle" class="bg-zinc-900 border border-[#2A2A2A] text-zinc-300 px-4 py-2 rounded font-['Space_Grotesk'] text-xs font-bold uppercase tracking-wider hover:border-[#FF8C00]/50 transition-all">Sideboard</button>
                    </div>
                </div>

                <!-- Search Results -->
                <div class="bg-[rgba(18,18,18,0.7)] backdrop-blur-xl border border-[#2A2A2A] rounded-xl overflow-hidden">
                    <div class="p-6 border-b border-[#2A2A2A]">
                        <h2 class="text-sm font-bold uppercase tracking-widest text-zinc-400 font-['Space_Grotesk']">Search Results</h2>
                    </div>
                    
                    <div id="searchResults" class="grid gap-4 p-6 max-h-[600px] overflow-y-auto" style="grid-template-columns: repeat(3, minmax(0, 1fr));">
                        <p class="col-span-full text-zinc-400 text-center py-8">Start typing to search for cards...</p>
                    </div>
                </div>
            </div>

            <!-- Right Panel - Deck Cards -->
            <div>
                <!-- Deck Stats -->
                <div class="bg-[rgba(18,18,18,0.7)] backdrop-blur-xl border border-[#2A2A2A] rounded-xl p-4 mb-4">
                    <div class="space-y-4 text-sm">
                        <div class="pb-4 border-b border-[#2A2A2A]">
                            <div class="flex items-center justify-between">
                                <span class="text-xs font-bold uppercase tracking-widest text-zinc-400 font-['Space_Grotesk']">Format:</span>
                                <span class="text-[#FF8C00] font-bold text-base capitalize">{{ deck.format }}</span>
                            </div>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-zinc-400">Main Deck:</span>
                            <span class="text-[#FF8C00] font-bold" id="deckTotal">{{ mainDeck|length }}</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-zinc-400">Sideboard:</span>
                            <span class="text-[#FF8C00] font-bold" id="sideboardTotal">{{ sideboard|length }}</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-zinc-400">Unique Cards:</span>
                            <span class="text-[#FF8C00] font-bold" id="deckUnique">0</span>
                        </div>
                    </div>
                </div>

                <!-- Save and Delete Buttons -->
                <div class="flex gap-2 mb-4">
                    <button onclick="document.getElementById('importModal').classList.remove('hidden')" class="flex-1 bg-zinc-900 border border-[#2A2A2A] text-zinc-300 px-4 py-2 rounded font-['Space_Grotesk'] text-xs font-bold uppercase tracking-wider hover:border-[#FF8C00]/50 transition-all flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined text-sm">upload</span>
                        Import
                    </button>
                    <button onclick="saveDeckChanges({{ deck.id }})" class="flex-1 bg-[#FF8C00] hover:bg-[#ff9d26] text-black px-4 py-2 rounded font-['Space_Grotesk'] text-xs font-bold uppercase tracking-wider transition-all flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined text-sm">save</span>
                        Save
                    </button>
                    <form method="post" action="{{ path('app_deck_delete', {id: deck.id}) }}" onsubmit="return confirm('Are you sure you want to delete this deck? This cannot be undone.');" class="flex-1 flex">
                        <button type="submit" class="flex-1 bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded font-['Space_Grotesk'] text-xs font-bold uppercase tracking-wider transition-all flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined text-sm">delete</span>
                            Delete
                        </button>
                    </form>
                </div>

                <!-- Deck Cards List View -->
                <div class="bg-[rgba(18,18,18,0.7)] backdrop-blur-xl border border-[#2A2A2A] rounded-xl overflow-hidden">
                    <!-- Main Deck Section -->
                    <div>
                        <div class="p-4 border-b border-[#2A2A2A] bg-zinc-900/50">
                            <h3 class="text-sm font-bold uppercase tracking-widest text-[#FF8C00] font-['Space_Grotesk']">Main Deck</h3>
                        </div>
                        <div id="deckCardsList" class="max-h-[300px] overflow-y-auto">
                            {% if mainDeck|length > 0 %}
                                {% for deckCard in mainDeck %}
                                    <div class="px-4 py-2 border-b border-[#2A2A2A] flex items-center justify-between hover:bg-zinc-900/30 transition-colors group" data-card-id="{{ deckCard.scryfallCard.scryfallId }}" data-is-sideboard="0">
                                        <div class="flex-1">
                                            <p class="text-sm text-white">{{ deckCard.scryfallCard.name }}</p>
                                        </div>
                                        <div class="flex items-center gap-2">
                                            <span class="text-[#FF8C00] font-bold text-sm">{{ deckCard.quantity }}x</span>
                                            <button onclick="removeCardFromDeck(this)" class="text-zinc-400 hover:text-red-500 transition-colors opacity-0 group-hover:opacity-100">
                                                <span class="material-symbols-outlined text-sm">delete</span>
                                            </button>
                                        </div>
                                    </div>
                                {% endfor %}
                            {% else %}
                                <p class="text-zinc-400 text-center py-8 text-sm">No cards in main deck</p>
                            {% endif %}
                        </div>
                    </div>

                    <!-- Sideboard Section -->
                    <div class="border-t border-[#2A2A2A]">
                        <div class="p-4 border-b border-[#2A2A2A] bg-zinc-900/50">
                            <h3 class="text-sm font-bold uppercase tracking-widest text-purple-400 font-['Space_Grotesk']">Sideboard</h3>
                        </div>
                        <div id="sideboardCardsList" class="max-h-[200px] overflow-y-auto">
                            {% if sideboard|length > 0 %}
                                {% for deckCard in sideboard %}
                                    <div class="px-4 py-2 border-b border-[#2A2A2A] flex items-center justify-between hover:bg-zinc-900/30 transition-colors group" data-card-id="{{ deckCard.scryfallCard.scryfallId }}" data-is-sideboard="1">
                                        <div class="flex-1">
                                            <p class="text-sm text-white">{{ deckCard.scryfallCard.name }}</p>
                                        </div>
                                        <div class="flex items-center gap-2">
                                            <span class="text-[#FF8C00] font-bold text-sm">{{ deckCard.quantity }}x</span>
                                            <button onclick="removeCardFromDeck(this)" class="text-zinc-400 hover:text-red-500 transition-colors opacity-0 group-hover:opacity-100">
                                                <span class="material-symbols-outlined text-sm">delete</span>
                                            </button>
                                        </div>
                                    </div>
                                {% endfor %}
                            {% else %}
                                <p class="text-zinc-400 text-center py-8 text-sm">No sideboard cards</p>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<!-- Import Deck Modal -->
<div id="importModal" class="fixed inset-0 bg-black/70 hidden flex items-center justify-center z-50 p-4">
    <div class="bg-[#1A1B1E] border border-[#2A2A2A] rounded-xl max-w-2xl w-full max-h-[90vh] overflow-y-auto">
        <div class="p-6 border-b border-[#2A2A2A] flex items-center justify-between sticky top-0 bg-[#1A1B1E]">
            <h2 class="text-lg font-bold uppercase tracking-widest text-[#FF8C00] font-['Space_Grotesk']">Import Decklist</h2>
            <button onclick="closeImportModal()" class="text-zinc-400 hover:text-white transition-colors">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        
        <div class="p-6 space-y-4">
            <p class="text-zinc-300 text-sm">Paste your decklist in the format below. The importer will replace your current deck.</p>
            
            <textarea id="decklistInput" class="w-full bg-[#121212] border border-[#2A2A2A] rounded-lg p-4 text-sm text-zinc-200 font-mono focus:border-[#FF8C00] outline-none resize-none" rows="12" placeholder="Deck&#10;4 Sneaky Snacker&#10;4 Voldaren Epicure&#10;18 Mountain&#10;&#10;Sideboard&#10;3 Smash to Smithereens&#10;2 End the Festivities"></textarea>
            
            <div id="importError" class="hidden bg-red-600/20 border border-red-600/50 text-red-400 p-3 rounded-lg text-sm"></div>
            
            <div class="flex gap-3">
                <button onclick="importDeckList()" class="flex-1 bg-[#FF8C00] hover:bg-[#ff9d26] text-black px-6 py-3 rounded-lg font-['Space_Grotesk'] text-sm font-bold uppercase tracking-wider transition-all">
                    Import
                </button>
                <button onclick="closeImportModal()" class="flex-1 bg-zinc-900 hover:bg-zinc-800 border border-[#2A2A2A] text-zinc-300 px-6 py-3 rounded-lg font-['Space_Grotesk'] text-sm font-bold uppercase tracking-wider transition-all">
                    Cancel
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    const deckId = {{ deck.id }};
    const deckFormat = '{{ deck.format }}';
    let deckCards = {};
    let addToSideboard = false;
    let searchTimeout;

    // Initialize deck cards from existing data
    {% for deckCard in mainDeck %}
        addToCardList('{{ deckCard.scryfallCard.scryfallId }}', '{{ deckCard.scryfallCard.name }}', {{ deckCard.quantity }}, false);
    {% endfor %}
    {% for deckCard in sideboard %}
        addToCardList('{{ deckCard.scryfallCard.scryfallId }}', '{{ deckCard.scryfallCard.name }}', {{ deckCard.quantity }}, true);
    {% endfor %}

    // Sideboard toggle
    document.getElementById('mainDeckToggle').addEventListener('click', function() {
        addToSideboard = false;
        this.classList.add('bg-[#FF8C00]', 'text-black');
        this.classList.remove('bg-zinc-900', 'border', 'text-zinc-300', 'border-[#2A2A2A]');
        document.getElementById('sideboardToggle').classList.remove('bg-[#FF8C00]', 'text-black');
        document.getElementById('sideboardToggle').classList.add('bg-zinc-900', 'border', 'border-[#2A2A2A]', 'text-zinc-300');
    });

    document.getElementById('sideboardToggle').addEventListener('click', function() {
        addToSideboard = true;
        this.classList.add('bg-[#FF8C00]', 'text-black');
        this.classList.remove('bg-zinc-900', 'border', 'text-zinc-300', 'border-[#2A2A2A]');
        document.getElementById('mainDeckToggle').classList.remove('bg-[#FF8C00]', 'text-black');
        document.getElementById('mainDeckToggle').classList.add('bg-zinc-900', 'border', 'border-[#2A2A2A]', 'text-zinc-300');
    });

    // Columns selector
    document.getElementById('columnsSelector').addEventListener('change', function(e) {
        const cols = e.target.value;
        document.getElementById('searchResults').style.gridTemplateColumns = `repeat(${cols}, minmax(0, 1fr))`;
    });

    // Search cards
    document.getElementById('cardSearch').addEventListener('input', function(e) {
        clearTimeout(searchTimeout);
        const query = e.target.value.trim();
        const searchResults = document.getElementById('searchResults');

        if (query.length < 2) {
            searchResults.innerHTML = '<p class="col-span-full text-zinc-400 text-center py-8">Start typing to search for cards...</p>';
            return;
        }

        searchTimeout = setTimeout(() => {
            fetch(`{{ path('app_deck_search_cards') }}?q=${encodeURIComponent(query)}&format=${encodeURIComponent(deckFormat)}`)
                .then(response => response.json())
                .then(data => {
                    if (data.error) {
                        searchResults.innerHTML = `<p class="col-span-full text-red-400 text-center py-8">${data.error}</p>`;
                        return;
                    }
                    if (data.cards.length === 0) {
                        searchResults.innerHTML = '<p class="col-span-full text-zinc-400 text-center py-8">No cards found</p>';
                        return;
                    }
                    searchResults.innerHTML = data.cards.map(card => `
                        <div class="bg-[#121212] border border-[#2A2A2A] rounded-lg overflow-hidden hover:border-[#FF8C00]/50 transition-all cursor-pointer group" onclick="addCardToDeck('${card.id}', '${card.name.replace(/'/g, "\\'")}')">
                            <div class="relative aspect-[5/7] overflow-hidden bg-zinc-900 rounded-lg mb-2">
                                <img src="${card.image}" alt="${card.name}" class="w-full h-full object-cover group-hover:scale-110 transition-transform">
                            </div>
                            <div class="p-2">
                                <p class="text-xs font-bold text-white truncate">${card.name}</p>
                                <p class="text-xs text-zinc-400">${card.mana_cost}</p>
                            </div>
                        </div>
                    `).join('');
                })
                .catch(error => {
                    console.error('Search error:', error);
                    searchResults.innerHTML = '<p class="col-span-full text-red-400 text-center py-8">Error searching cards</p>';
                });
        }, 300);
    });

    function addCardToDeck(cardId, cardName) {
        const key = cardId + (addToSideboard ? '_sb' : '');
        addToCardList(cardId, cardName, 1, addToSideboard);
    }

    function addToCardList(cardId, cardName, quantity = 1, isSideboard = false) {
        const key = cardId + (isSideboard ? '_sb' : '');
        
        if (!deckCards[key]) {
            deckCards[key] = {
                id: cardId,
                name: cardName,
                quantity: 0,
                isSideboard: isSideboard
            };
        }
        
        deckCards[key].quantity += quantity;
        updateDeckDisplay();
    }

    function removeCardFromDeck(button) {
        const container = button.closest('[data-card-id]');
        const cardId = container.dataset.cardId;
        const isSideboard = container.dataset.isSideboard === '1';
        const key = cardId + (isSideboard ? '_sb' : '');
        delete deckCards[key];
        updateDeckDisplay();
    }

    function updateDeckDisplay() {
        const deckCardsList = document.getElementById('deckCardsList');
        const sideboardCardsList = document.getElementById('sideboardCardsList');
        
        let mainDeckHtml = '';
        let sideboardHtml = '';
        let mainDeckCount = 0;
        let sideboardCount = 0;
        let uniqueCards = Object.keys(deckCards).length;

        Object.values(deckCards).forEach(card => {
            const html = `
                <div class="px-4 py-2 border-b border-[#2A2A2A] flex items-center justify-between hover:bg-zinc-900/30 transition-colors group" data-card-id="${card.id}" data-is-sideboard="${card.isSideboard ? 1 : 0}">
                    <div class="flex-1">
                        <p class="text-sm text-white">${card.name}</p>
                    </div>
                    <div class="flex items-center gap-2">
                        <span class="text-[#FF8C00] font-bold text-sm">${card.quantity}x</span>
                        <button onclick="removeCardFromDeck(this)" class="text-zinc-400 hover:text-red-500 transition-colors opacity-0 group-hover:opacity-100">
                            <span class="material-symbols-outlined text-sm">delete</span>
                        </button>
                    </div>
                </div>
            `;

            if (card.isSideboard) {
                sideboardHtml += html;
                sideboardCount += card.quantity;
            } else {
                mainDeckHtml += html;
                mainDeckCount += card.quantity;
            }
        });

        deckCardsList.innerHTML = mainDeckHtml || '<p class="text-zinc-400 text-center py-8 text-sm">No cards in main deck</p>';
        sideboardCardsList.innerHTML = sideboardHtml || '<p class="text-zinc-400 text-center py-8 text-sm">No sideboard cards</p>';
        
        document.getElementById('deckTotal').textContent = mainDeckCount;
        document.getElementById('sideboardTotal').textContent = sideboardCount;
        document.getElementById('deckUnique').textContent = uniqueCards;
    }

    function saveDeckChanges(deckId) {
        const mainDeckCards = {};
        const sideboardCards = {};

        Object.values(deckCards).forEach(card => {
            if (card.isSideboard) {
                sideboardCards[card.id] = card.quantity;
            } else {
                mainDeckCards[card.id] = card.quantity;
            }
        });

        fetch(`/deck/${deckId}/update-cards`, {
            method: 'POST',
            headers: {
                'X-Requested-With': 'XMLHttpRequest',
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({
                mainDeck: mainDeckCards,
                sideboard: sideboardCards,
            }),
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                const successMsg = document.createElement('div');
                successMsg.className = 'fixed top-4 right-4 bg-green-900/20 border border-green-900/60 text-green-100 px-6 py-4 rounded-xl flex items-center gap-3 z-50';
                successMsg.innerHTML = `<span class="material-symbols-outlined text-green-500">check_circle</span><span class="font-['Space_Grotesk'] text-sm">Deck updated successfully</span>`;
                document.body.appendChild(successMsg);
                setTimeout(() => successMsg.remove(), 3000);
            } else {
                const errorMsg = document.createElement('div');
                errorMsg.className = 'fixed top-4 right-4 bg-red-900/20 border border-red-900/60 text-red-100 px-6 py-4 rounded-xl flex items-center gap-3 z-50';
                errorMsg.innerHTML = `<span class="material-symbols-outlined text-red-500">error</span><span class="font-['Space_Grotesk'] text-sm">${data.error || 'Failed to update deck'}</span>`;
                document.body.appendChild(errorMsg);
                setTimeout(() => errorMsg.remove(), 5000);
            }
        })
        .catch(error => {
            console.error('Error:', error);
            const errorMsg = document.createElement('div');
            errorMsg.className = 'fixed top-4 right-4 bg-red-900/20 border border-red-900/60 text-red-100 px-6 py-4 rounded-xl flex items-center gap-3 z-50';
            errorMsg.innerHTML = `<span class="material-symbols-outlined text-red-500">error</span><span class="font-['Space_Grotesk'] text-sm">Error updating deck</span>`;
            document.body.appendChild(errorMsg);
            setTimeout(() => errorMsg.remove(), 3000);
        });
    }

    function closeImportModal() {
        document.getElementById('importModal').classList.add('hidden');
        document.getElementById('decklistInput').value = '';
        document.getElementById('importError').classList.add('hidden');
    }

    async function importDeckList() {
        const content = document.getElementById('decklistInput').value.trim();
        const importError = document.getElementById('importError');
        
        if (!content) {
            showImportError('Decklist cannot be empty');
            return;
        }

        // Parse deck and sideboard
        const lines = content.split('\n').map(l => l.trim()).filter(l => l);
        let deck = {};
        let sideboard = {};
        let currentSection = 'deck';

        for (const line of lines) {
            if (line.toLowerCase() === 'deck') {
                currentSection = 'deck';
                continue;
            }
            if (line.toLowerCase() === 'sideboard') {
                currentSection = 'sideboard';
                continue;
            }

            // Parse "4 Sneaky Snacker" format
            const match = line.match(/^(\d+)\s+(.+)$/);
            if (match) {
                const count = parseInt(match[1]);
                const cardName = match[2].trim();
                
                if (currentSection === 'deck') {
                    deck[cardName] = count;
                } else {
                    sideboard[cardName] = count;
                }
            }
        }

        // Import cards
        try {
            const importedCards = {};

            for (const [cardName, count] of Object.entries(deck)) {
                const cards = await searchCardByName(cardName);
                if (!cards || cards.length === 0) {
                    showImportError(`Card not found: "${cardName}"`);
                    return;
                }

                const card = cards[0];
                importedCards[card.id] = {
                    id: card.id,
                    name: card.name,
                    quantity: count,
                    isSideboard: false
                };
            }

            // Import sideboard cards
            for (const [cardName, count] of Object.entries(sideboard)) {
                const cards = await searchCardByName(cardName);
                if (!cards || cards.length === 0) {
                    showImportError(`Card not found in sideboard: "${cardName}"`);
                    return;
                }

                const card = cards[0];
                if (importedCards[card.id]) {
                    importedCards[card.id].quantity += count;
                } else {
                    importedCards[card.id] = {
                        id: card.id,
                        name: card.name,
                        quantity: count,
                        isSideboard: true
                    };
                }
            }

            // Clear and update deck
            deckCards = importedCards;
            updateDeckDisplay();
            closeImportModal();
        } catch (error) {
            console.error('Import error:', error);
            showImportError('Error importing deck. Please check the format.');
        }
    }

    function showImportError(message) {
        const importError = document.getElementById('importError');
        importError.textContent = message;
        importError.classList.remove('hidden');
    }

    async function searchCardByName(name) {
        try {
            const response = await fetch(`https://api.scryfall.com/cards/search?q=${encodeURIComponent(name)}`);
            const data = await response.json();
            if (!data.data || data.data.length === 0) return [];
            
            // Find exact match
            const exact = data.data.find(card => card.name.toLowerCase() === name.toLowerCase());
            return exact ? [exact] : data.data;
        } catch (error) {
            console.error('Search error:', error);
            return [];
        }
    }
</script>
{% endblock %}
