{% extends 'base.html.twig' %}

{% block title %}My Collection - ManaHoarder{% endblock %}

{% block body %}
<main class="min-h-screen">
    <div class="max-w-[1440px] mx-auto p-8 lg:p-12">
        <!-- Header Section -->
        <div class="mb-10 flex justify-between items-start">
            <div>
                <h1 class="font-['Space_Grotesk'] text-[40px] leading-[1.2] tracking-tighter font-bold text-[#FF8C00] mb-2 uppercase">Card Vault</h1>
                <p class="text-zinc-400 max-w-2xl">Organize your collection into albums and track your card inventory.</p>
            </div>
            <div class="flex gap-3">
                <button class="bg-zinc-900 border border-[#2A2A2A] text-zinc-300 px-5 py-3 rounded font-['Space_Grotesk'] text-xs font-bold uppercase tracking-wider hover:border-[#FF8C00]/50 transition-all flex items-center gap-2">
                    <span class="material-symbols-outlined text-sm">upload</span>
                    Import Collection
                </button>
                <button class="bg-[#FF8C00] text-black px-5 py-3 rounded font-['Space_Grotesk'] text-xs font-bold uppercase tracking-wider hover:brightness-110 transition-all flex items-center gap-2">
                    <span class="material-symbols-outlined text-sm">add</span>
                    Create Album
                </button>
            </div>
        </div>

        {% if albums is defined and albums|length > 0 %}
            <!-- Filters and Search Bar -->
            <div class="mb-8 bg-[rgba(18,18,18,0.7)] backdrop-blur-xl border border-[#2A2A2A] p-6 rounded-xl">
                <div class="grid grid-cols-1 lg:grid-cols-12 gap-4">
                    <!-- Search Bar -->
                    <div class="lg:col-span-6">
                        <label class="block text-[10px] font-bold uppercase tracking-widest text-zinc-500 font-['Space_Grotesk'] mb-2">Search Albums</label>
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-zinc-500">search</span>
                            <input 
                                type="text" 
                                placeholder="Search by album name or set..." 
                                class="w-full bg-[#121212] border border-[#2A2A2A] py-3 pl-10 pr-3 text-xs text-zinc-300 placeholder-zinc-600 font-['Space_Grotesk'] tracking-wide focus:border-[#FF8C00] outline-none rounded"
                            >
                        </div>
                    </div>

                    <!-- Sort By -->
                    <div class="lg:col-span-3">
                        <label class="block text-[10px] font-bold uppercase tracking-widest text-zinc-500 font-['Space_Grotesk'] mb-2">Sort By</label>
                        <select class="w-full bg-[#121212] border border-[#2A2A2A] py-3 px-3 text-xs text-zinc-300 font-['Space_Grotesk'] tracking-wide focus:border-[#FF8C00] outline-none rounded">
                            <option value="recent">Recently Updated</option>
                            <option value="name">Album Name</option>
                            <option value="cards">Card Count</option>
                            <option value="value">Total Value</option>
                        </select>
                    </div>

                    <!-- View Mode -->
                    <div class="lg:col-span-3">
                        <label class="block text-[10px] font-bold uppercase tracking-widest text-zinc-500 font-['Space_Grotesk'] mb-2">View Mode</label>
                        <div class="flex gap-2">
                            <button class="flex-1 bg-[#FF8C00] border border-[#FF8C00] text-black py-3 px-3 rounded hover:brightness-110 transition-all">
                                <span class="material-symbols-outlined text-sm">grid_view</span>
                            </button>
                            <button class="flex-1 bg-[#121212] border border-[#2A2A2A] text-zinc-400 py-3 px-3 rounded hover:border-[#FF8C00]/50 transition-all">
                                <span class="material-symbols-outlined text-sm">view_list</span>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Collection Stats -->
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
                <div class="bg-[rgba(18,18,18,0.7)] backdrop-blur-xl border border-[#2A2A2A] p-5 rounded-xl">
                    <div class="flex items-center gap-3 mb-2">
                        <span class="material-symbols-outlined text-[#FF8C00]">style</span>
                        <span class="text-[10px] font-bold uppercase tracking-widest text-zinc-500 font-['Space_Grotesk']">Total Cards</span>
                    </div>
                    <div class="text-3xl font-['Space_Grotesk'] font-bold text-white">4,821</div>
                </div>
                <div class="bg-[rgba(18,18,18,0.7)] backdrop-blur-xl border border-[#2A2A2A] p-5 rounded-xl">
                    <div class="flex items-center gap-3 mb-2">
                        <span class="material-symbols-outlined text-[#FF8C00]">folder</span>
                        <span class="text-[10px] font-bold uppercase tracking-widest text-zinc-500 font-['Space_Grotesk']">Albums</span>
                    </div>
                    <div class="text-3xl font-['Space_Grotesk'] font-bold text-white">{{ albums|length }}</div>
                </div>
                <div class="bg-[rgba(18,18,18,0.7)] backdrop-blur-xl border border-[#2A2A2A] p-5 rounded-xl">
                    <div class="flex items-center gap-3 mb-2">
                        <span class="material-symbols-outlined text-[#FF8C00]">auto_awesome</span>
                        <span class="text-[10px] font-bold uppercase tracking-widest text-zinc-500 font-['Space_Grotesk']">Unique Cards</span>
                    </div>
                    <div class="text-3xl font-['Space_Grotesk'] font-bold text-white">1,247</div>
                </div>
                <div class="bg-[rgba(18,18,18,0.7)] backdrop-blur-xl border border-[#2A2A2A] p-5 rounded-xl">
                    <div class="flex items-center gap-3 mb-2">
                        <span class="material-symbols-outlined text-[#FF8C00]">payments</span>
                        <span class="text-[10px] font-bold uppercase tracking-widest text-zinc-500 font-['Space_Grotesk']">Est. Value</span>
                    </div>
                    <div class="text-3xl font-['Space_Grotesk'] font-bold text-white">$8,420</div>
                </div>
            </div>

            <!-- Albums Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                {% for album in albums %}
                    <div class="bg-[#1A1B1E] border border-[#2A2A2A] hover:border-[#FF8C00]/50 transition-all rounded overflow-hidden group cursor-pointer">
                        <div class="relative h-48 overflow-hidden bg-zinc-900">
                            {% if album.coverImage %}
                                <img alt="{{ album.name }}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" src="{{ album.coverImage }}"/>
                            {% else %}
                                <div class="w-full h-full flex items-center justify-center">
                                    <span class="material-symbols-outlined text-6xl text-zinc-700">photo_library</span>
                                </div>
                            {% endif %}
                            <div class="absolute top-2 right-2 bg-black/60 backdrop-blur px-2 py-1 rounded text-[10px] font-['Space_Grotesk'] text-zinc-300 border border-zinc-700">
                                {{ album.cardCount ?? 0 }} Cards
                            </div>
                        </div>
                        <div class="p-4">
                            <h3 class="font-['Space_Grotesk'] text-lg font-semibold text-white mb-1">{{ album.name }}</h3>
                            <p class="text-xs text-zinc-500 mb-4">{{ album.description ?? 'No description' }}</p>
                            
                            <div class="flex items-center justify-between pt-3 border-t border-zinc-800">
                                <div class="flex items-center gap-2 text-zinc-400">
                                    <span class="material-symbols-outlined text-sm">update</span>
                                    <span class="text-[10px] font-['Space_Grotesk']">{{ album.updatedAt|date('M d, Y') }}</span>
                                </div>
                                <button class="text-zinc-500 hover:text-red-500 transition-colors">
                                    <span class="material-symbols-outlined text-lg">delete</span>
                                </button>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>

        {% else %}
            <!-- Empty State -->
            <div class="flex items-center justify-center min-h-[60vh]">
                <div class="text-center max-w-md">
                    <div class="w-24 h-24 rounded-full bg-zinc-900 border border-[#2A2A2A] flex items-center justify-center mx-auto mb-6">
                        <span class="material-symbols-outlined text-5xl text-zinc-600">photo_library</span>
                    </div>
                    <h2 class="font-['Space_Grotesk'] text-2xl font-semibold text-white mb-3 uppercase tracking-tight">No Albums Yet</h2>
                    <p class="text-zinc-400 mb-8">Start organizing your card collection. Create albums to categorize your cards by set, rarity, or any custom criteria.</p>
                    
                    <div class="flex flex-col sm:flex-row gap-3 justify-center">
                        <button class="bg-[#FF8C00] text-black px-6 py-3 rounded font-['Space_Grotesk'] text-xs font-bold uppercase tracking-wider hover:brightness-110 transition-all flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined text-sm">add</span>
                            Create Your First Album
                        </button>
                        <button class="bg-zinc-900 border border-[#2A2A2A] text-zinc-300 px-6 py-3 rounded font-['Space_Grotesk'] text-xs font-bold uppercase tracking-wider hover:border-[#FF8C00]/50 transition-all flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined text-sm">upload</span>
                            Import Collection
                        </button>
                    </div>

                    <div class="mt-8 p-4 bg-[rgba(18,18,18,0.7)] backdrop-blur-xl border border-[#2A2A2A] rounded-xl">
                        <div class="flex items-start gap-3">
                            <span class="material-symbols-outlined text-[#FF8C00] text-xl">info</span>
                            <div class="text-left">
                                <h3 class="font-['Space_Grotesk'] text-sm font-semibold text-white mb-1 uppercase tracking-wide">Quick Tip</h3>
                                <p class="text-xs text-zinc-400">Albums help you organize your collection by themes like "Commander Staples", "Modern Playables", or "Foil Collection". You can also import your collection from CSV files.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        {% endif %}
    </div>
</main>
{% endblock %}
