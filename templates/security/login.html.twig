<!DOCTYPE html>
<html class="dark" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>Login | ManaHoarder</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "surface-container-highest": "#3f3229",
                        "on-tertiary-fixed-variant": "#004c6c",
                        "on-surface-variant": "#ddc1ae",
                        "on-tertiary-container": "#004360",
                        "on-error": "#690005",
                        "inverse-surface": "#f3dfd1",
                        "error": "#ffb4ab",
                        "surface-container": "#281d15",
                        "on-background": "#f3dfd1",
                        "on-tertiary": "#00344c",
                        "error-container": "#93000a",
                        "inverse-on-surface": "#3a2e25",
                        "surface-tint": "#ffb77d",
                        "on-secondary-fixed-variant": "#46474a",
                        "on-primary": "#4d2600",
                        "on-secondary-fixed": "#1a1b1e",
                        "on-error-container": "#ffdad6",
                        "surface-bright": "#43372e",
                        "inverse-primary": "#904d00",
                        "primary-container": "#ff8c00",
                        "tertiary-container": "#00b5fc",
                        "tertiary-fixed": "#c7e7ff",
                        "surface-container-lowest": "#150c06",
                        "surface-dim": "#1b110a",
                        "surface-container-low": "#241912",
                        "surface": "#1b110a",
                        "secondary-fixed-dim": "#c7c6ca",
                        "on-tertiary-fixed": "#001e2e",
                        "on-secondary": "#2f3033",
                        "background": "#1b110a",
                        "on-primary-fixed": "#2f1500",
                        "on-secondary-container": "#b9b8bc",
                        "on-primary-container": "#623200",
                        "secondary-container": "#48494c",
                        "secondary-fixed": "#e3e2e6",
                        "outline-variant": "#564334",
                        "on-surface": "#f3dfd1",
                        "primary-fixed-dim": "#ffb77d",
                        "on-primary-fixed-variant": "#6e3900",
                        "primary-fixed": "#ffdcc3",
                        "primary": "#ffb77d",
                        "surface-container-high": "#33281f",
                        "outline": "#a48c7a",
                        "tertiary": "#85cfff",
                        "secondary": "#c7c6ca",
                        "surface-variant": "#3f3229",
                        "tertiary-fixed-dim": "#85cfff"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.125rem",
                        "lg": "0.25rem",
                        "xl": "0.5rem",
                        "full": "0.75rem"
                    },
                    "spacing": {
                        "sm": "12px",
                        "gutter": "16px",
                        "lg": "48px",
                        "container-max": "1440px",
                        "xs": "4px",
                        "md": "24px",
                        "base": "8px"
                    },
                    "fontFamily": {
                        "body-sm": ["Inter"],
                        "h1": ["Space Grotesk"],
                        "data-mono": ["Space Grotesk"],
                        "h2": ["Space Grotesk"],
                        "body-lg": ["Inter"],
                        "h3": ["Space Grotesk"]
                    },
                    "fontSize": {
                        "body-sm": ["14px", {"lineHeight": "1.5", "fontWeight": "400"}],
                        "h1": ["40px", {"lineHeight": "1.2", "letterSpacing": "-0.02em", "fontWeight": "700"}],
                        "data-mono": ["13px", {"lineHeight": "1.0", "letterSpacing": "0.05em", "fontWeight": "500"}],
                        "h2": ["24px", {"lineHeight": "1.3", "fontWeight": "600"}],
                        "body-lg": ["16px", {"lineHeight": "1.6", "fontWeight": "400"}],
                        "h3": ["18px", {"lineHeight": "1.4", "fontWeight": "600"}]
                    }
                }
            }
        }
    </script>
    <style>
        body {
            background-color: #1b110a;
            color: #f3dfd1;
        }
        .glass-panel {
            background: rgba(18, 18, 18, 0.8);
            backdrop-filter: blur(12px);
            border: 1px solid #2A2A2A;
        }
        .tactical-input {
            background-color: #121212;
            border-color: #2A2A2A;
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
        }
        .tactical-input:focus {
            border-color: #ff8c00;
            box-shadow: 0 0 0 1px rgba(255, 140, 0, 0.2);
            outline: none;
        }
        .mtg-pattern {
            background-image: radial-gradient(#2A2A2A 0.5px, transparent 0.5px);
            background-size: 24px 24px;
            opacity: 0.2;
        }
    </style>
</head>
<body class="font-body-lg text-body-lg min-h-screen flex flex-col selection:bg-primary-container selection:text-on-primary-container">
<!-- TopNavBar (Shared Component) -->
<header class="bg-surface fixed top-0 left-0 w-full z-50 border-b border-outline-variant">
    <div class="flex justify-between items-center w-full px-gutter py-base max-w-container-max mx-auto">
        <div class="font-h2 text-h2 font-bold text-primary">ManaHoarder</div>
        <nav class="hidden md:flex items-center space-x-md">
            <a class="text-on-surface-variant hover:text-on-surface transition-colors font-h3 text-h3" href="#">Dashboard</a>
            <a class="text-on-surface-variant hover:text-on-surface transition-colors font-h3 text-h3" href="#">Decks</a>
            <a class="text-on-surface-variant hover:text-on-surface transition-colors font-h3 text-h3" href="#">Collection</a>
        </nav>
        <div class="flex items-center gap-sm">
            <button class="hidden md:block bg-primary-container text-on-primary-container px-gutter py-xs rounded hover:bg-surface-container-highest transition-all duration-200 active:scale-95 opacity-80 font-h3 text-h3">
                Sync Collection
            </button>
            <button class="material-symbols-outlined text-primary p-xs hover:bg-surface-container-highest rounded-full transition-all" data-icon="search">search</button>
        </div>
    </div>
</header>
<!-- Main Content Area -->
<main class="flex-grow relative flex items-center justify-center pt-lg overflow-hidden">
    <!-- Background Decorative Element -->
    <div class="absolute inset-0 pointer-events-none z-0">
        <div class="mtg-pattern absolute inset-0"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-primary opacity-[0.03] rounded-full blur-[120px]"></div>
    </div>
    <div class="relative z-10 w-full max-w-[440px] px-gutter">
        <!-- Login Card -->
        <div class="glass-panel p-md md:p-lg rounded-lg shadow-lg border border-outline-variant flex flex-col gap-md">
            <div class="text-center space-y-xs">
                <h1 class="font-h1 text-h1 text-on-surface">Welcome Back</h1>
                <p class="font-body-sm text-body-sm text-on-surface-variant">Access your tactical card repository</p>
            </div>
            <!-- Form -->
            <form class="flex flex-col gap-sm" method="post">
                {% if error %}
                    <div class="bg-error-container text-on-error-container p-sm rounded-lg font-body-sm text-body-sm">
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}
                
                <div class="flex flex-col gap-xs">
                    <label class="font-data-mono text-data-mono text-primary uppercase tracking-wider" for="email">Email Address</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-sm top-1/2 -translate-y-1/2 text-on-surface-variant" data-icon="mail">mail</span>
                        <input class="tactical-input w-full pl-lg pr-sm py-sm rounded-lg text-on-surface font-body-sm placeholder:text-surface-container-highest" id="email" name="_username" value="{{ last_username }}" placeholder="strategist@manahoarder.com" type="email" autocomplete="email" required autofocus/>
                    </div>
                </div>
                <div class="flex flex-col gap-xs">
                    <div class="flex justify-between items-center">
                        <label class="font-data-mono text-data-mono text-primary uppercase tracking-wider" for="password">Password</label>
                        <a class="font-data-mono text-data-mono text-tertiary hover:underline" href="#">Forgot Password?</a>
                    </div>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-sm top-1/2 -translate-y-1/2 text-on-surface-variant" data-icon="lock">lock</span>
                        <input class="tactical-input w-full pl-lg pr-sm py-sm rounded-lg text-on-surface font-body-sm placeholder:text-surface-container-highest" id="password" name="_password" placeholder="••••••••" type="password" autocomplete="current-password" required/>
                    </div>
                </div>
                <div class="flex items-center gap-xs py-xs">
                    <input class="w-4 h-4 rounded border-outline-variant bg-surface-dim text-primary focus:ring-primary" id="remember" name="_remember_me" type="checkbox"/>
                    <label class="font-body-sm text-body-sm text-on-surface-variant cursor-pointer" for="remember">Stay synced for 30 days</label>
                </div>
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                <button class="w-full bg-primary-container text-on-primary-container font-h3 text-h3 py-sm rounded-lg hover:brightness-110 active:scale-[0.98] transition-all flex justify-center items-center gap-xs" type="submit">
                    Login to ManaHoarder
                    <span class="material-symbols-outlined" data-icon="login">login</span>
                </button>
            </form>
            <div class="relative flex items-center py-base">
                <div class="flex-grow border-t border-outline-variant"></div>
                <span class="flex-shrink mx-gutter font-data-mono text-data-mono text-on-surface-variant">OR CONTINUE WITH</span>
                <div class="flex-grow border-t border-outline-variant"></div>
            </div>
            <div class="flex flex-col gap-sm">
                <button class="w-full tactical-input bg-surface-container-low text-on-surface border border-outline-variant font-h3 text-h3 py-sm rounded-lg hover:bg-surface-container-high transition-all flex justify-center items-center gap-sm">
                    <span class="material-symbols-outlined text-[#5865F2]" data-icon="rocket_launch">rocket_launch</span>
                    Login with Discord
                </button>
            </div>
            <p class="text-center font-body-sm text-body-sm text-on-surface-variant mt-base">
                Don't have an account? 
                <a class="text-primary font-bold hover:underline" href="{{ path('app_register') }}">Sign up</a>
            </p>
        </div>
        <!-- Visual Decorative Content below the card -->
        <div class="mt-md flex justify-center items-center gap-lg opacity-40 grayscale hover:grayscale-0 transition-all duration-500">
            <img alt="Plains" class="w-6 h-6 rounded-full" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCRotTshTeFyL7yc6Sp48woNq8I6b5O-qMzibkZ7vr6bMnUKOHmbJY9QJ4On0i8XOIcRKvxHFeuf7B-J1LU9X9ESLc7R4IhvPWULaO0J6QhABSGw55vRhtoeDSiRRbvyivK6Q-31aatOhaOQs2veuYjm2GZhiMdKAusncH5sfTyhdjbi0tjUIV40aB38JknVS4ciaaEdpBGI6p_ZdwehvN4LYp0qOE1RN0Ug_Tv_jX36UeGcqK9fgqpLtWcVI_JD9QeLkur46mRA-lc"/>
            <img alt="Island" class="w-6 h-6 rounded-full" src="https://lh3.googleusercontent.com/aida-public/AB6AXuB0OGp5UTc7LQpdrguobCzHnvrUwrvp6b2wT-stGkABbQl6qV8lFuEpeLNYMuvO30RcVUT2vpqTmvRO6Vo0UU5GLJhEiO_Ig1lEaUUHTE50Zk2ZBBtgKv0sfAcZ4xqH9rBNNz1cH1rzQcnuC4vGtAhsQGfSoFhyNfBpX3PPdt6LBc4qXLwAd_ySBHlDuPn0PrpoDBl5YCkW5Y8U6EljlrkXsjuusziUSzlYxsMwDmCpw20oHRb0FEUJmlnxips2YPgddYjLex8VbBUc"/>
            <img alt="Swamp" class="w-6 h-6 rounded-full" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAN48_lTQ45eL88xDdKnSBVSr5_T-vcNVJUjdBB0oJcb8M4t733JIasjG3LbZisqLVsaysyaAIFclGGku9f9V5VuiQiG8oNy_UdipZnlBGcW1yL95VQzLhxEGaAz0GhEvMRu8LBEZIfZ26ylPEM8whUwcunKZ8N9RtKlxELqzdLvZI-5HgpeowejGspiQRZdpC9hEJq6eZdw5ykC0lnJ8qT9SOn-CN2HoO3dJi1VVv2FK8OqBjGLmqp0JhfAGWIlFmIQs906FZZ5Pw"/>
        </div>
    </div>
</main>
<!-- Background Image Layer -->
<div class="fixed inset-0 -z-10 opacity-10">
    <img class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuA6ZtCyBLhXpcgANopFYyDZXPh1FJOKJbqqV2aCFaYsI7ZE4Q5_s7depjRQtToYu5JgFUzvojLQc0qU1kOtlbUWCWNVqqyn3ls6dianDaRUQNyiBA8rpVgDbJXNfKAs-DOSXmaKEE9QfP1T0lMFg5KN3bY3wpwo135HE1j5H3QbedN1H3vtmrfbg-m96wv17mSvZhg2NDIK79klKVRGLNMl0AElhepWWxR6fngNbVCapCj4N0rWejJJiHCGtpOkft2JpVxFN6nj82cG"/>
</div>
</body>
</html>
