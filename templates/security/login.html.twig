{% extends 'base.html.twig' %}

{% block title %}Sign In - ManaHoarder{% endblock %}

{% block body %}
<main class="min-h-screen overflow-y-auto">
    <div class="p-6">
        <div class="max-w-5xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-6">

            <section class="border border-[#2A2A2A] bg-[#121212] p-6">
                <h1 class="text-xl font-bold uppercase tracking-widest font-['Space_Grotesk'] text-[#FF8C00]">Sign In</h1>
                <p class="mt-2 text-zinc-500 text-sm">Access your account to manage your lists and decks.</p>

                {% if error %}
                    <div class="mt-4 border border-red-900/60 bg-red-900/20 px-4 py-3 text-sm text-red-100">
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                <form method="post" class="mt-6 space-y-4">
                    <div>
                        <label for="inputEmail" class="block text-[10px] font-bold uppercase tracking-widest text-zinc-500 font-['Space_Grotesk'] mb-1">Email</label>
                        <input type="email" value="{{ last_username }}" name="_username" id="inputEmail" placeholder="your@email.com" class="w-full bg-[#121212] border border-[#2A2A2A] py-3 px-3 text-xs font-['Space_Grotesk'] tracking-widest uppercase focus:border-[#FF8C00] outline-none" autocomplete="email" required autofocus>
                    </div>

                    <div>
                        <label for="inputPassword" class="block text-[10px] font-bold uppercase tracking-widest text-zinc-500 font-['Space_Grotesk'] mb-1">Password</label>
                        <input type="password" name="_password" id="inputPassword" placeholder="your password" class="w-full bg-[#121212] border border-[#2A2A2A] py-3 px-3 text-xs font-['Space_Grotesk'] tracking-widest uppercase focus:border-[#FF8C00] outline-none" autocomplete="current-password" required>
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    <button type="submit" class="w-full bg-[#FF8C00] text-black py-3 text-[10px] font-black uppercase tracking-widest rounded hover:bg-[#ff9d26] transition-colors">
                        Sign In
                    </button>

                    <p class="text-xs text-zinc-500">
                        Don't have an account?
                        <a class="text-[#FF8C00] font-bold hover:underline" href="{{ path('app_register') }}">Register</a>.
                    </p>
                </form>
            </section>

            <section class="border border-[#2A2A2A] bg-[#1A1B1E]/50 p-6">
                <h2 class="text-xl font-bold uppercase tracking-widest font-['Space_Grotesk']">New here?</h2>
                <p class="mt-2 text-zinc-500 text-sm">Create a free account and start building your decks.</p>

                <div class="mt-6 space-y-3">
                    <div class="border border-[#2A2A2A] bg-[#121212] p-4">
                        <div class="flex items-start gap-3">
                            <span class="material-symbols-outlined text-[#FF8C00]">person_add</span>
                            <div>
                                <div class="text-xs font-bold uppercase tracking-widest text-zinc-200 font-['Space_Grotesk']">Quick Registration</div>
                                <div class="mt-1 text-sm text-zinc-500">You only need an email and password to get started.</div>
                            </div>
                        </div>
                    </div>

                    <a class="block text-center bg-[#FF8C00] text-black px-4 py-3 text-[10px] font-black uppercase tracking-widest rounded hover:bg-[#ff9d26] transition-colors" href="{{ path('app_register') }}">
                        Create Account
                    </a>

                    <a class="block text-center border border-[#2A2A2A] px-4 py-3 text-[10px] font-black uppercase tracking-widest text-zinc-300 hover:bg-zinc-800 transition-colors rounded" href="{{ path('app_home') }}">
                        Back to Home
                    </a>

                    <p class="text-[11px] text-zinc-500">
                        We can add OAuth (Google/Discord) later if you're interested.
                    </p>
                </div>
            </section>

        </div>
    </div>
</main>
{% endblock %}
