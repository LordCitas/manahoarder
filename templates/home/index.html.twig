{% extends 'base.html.twig' %}

{% block title %}Command Center - ManaHoarder{% endblock %}

{% block body %}
<main class="min-h-screen">
    <div class="max-w-[1440px] mx-auto p-8 lg:p-12">
        <!-- Header Section -->
        <div class="mb-10">
            <h1 class="font-['Space_Grotesk'] text-[40px] leading-[1.2] tracking-tighter font-bold text-[#FF8C00] mb-2 uppercase">Command Center</h1>
            <p class="text-zinc-400 max-w-2xl">Manage your multicomponent deck library, analyze collection metrics, and optimize your competitive strategy.</p>
        </div>

        <!-- Dashboard Bento Grid -->
        <div class="grid grid-cols-12 gap-4">
            <!-- Collection Stats (Large Tile) -->
            <div class="col-span-12 lg:col-span-8 bg-[rgba(18,18,18,0.7)] backdrop-blur-xl border border-[#2A2A2A] p-6 rounded-xl flex flex-col justify-between">
                <div class="flex justify-between items-start mb-8">
                    <div>
                        <h2 class="font-['Space_Grotesk'] text-2xl font-semibold text-white mb-1 uppercase tracking-tight">Collection Overview</h2>
                        <p class="text-zinc-500 text-sm font-['Space_Grotesk'] tracking-wider">LAST ANALYZED: 12M AGO</p>
                    </div>
                    <div class="flex gap-2">
                        <span class="bg-zinc-900 border border-zinc-700 px-3 py-1 rounded-full text-xs font-['Space_Grotesk'] text-zinc-300">Total Cards: 4,821</span>
                    </div>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div class="bg-zinc-900/50 p-4 rounded border border-zinc-800 flex flex-col gap-2">
                        <span class="text-zinc-500 font-['Space_Grotesk'] text-[10px] uppercase tracking-wider">Unique Rares</span>
                        <span class="text-3xl font-['Space_Grotesk'] font-bold text-white">412</span>
                        <div class="h-1 bg-zinc-800 rounded-full w-full overflow-hidden">
                            <div class="h-full bg-gradient-to-r from-[#FF8C00] to-[#ff9d26] w-[65%]"></div>
                        </div>
                    </div>
                    <div class="bg-zinc-900/50 p-4 rounded border border-zinc-800 flex flex-col gap-2">
                        <span class="text-zinc-500 font-['Space_Grotesk'] text-[10px] uppercase tracking-wider">Mythic Density</span>
                        <span class="text-3xl font-['Space_Grotesk'] font-bold text-white">84</span>
                        <span class="text-zinc-400 text-xs font-['Space_Grotesk'] tracking-wider">TOP 5% OF USERS</span>
                    </div>
                    <div class="bg-zinc-900/50 p-4 rounded border border-zinc-800 flex flex-col gap-2">
                        <span class="text-zinc-500 font-['Space_Grotesk'] text-[10px] uppercase tracking-wider">Completion Rate</span>
                        <span class="text-3xl font-['Space_Grotesk'] font-bold text-white">74.2%</span>
                        <span class="text-zinc-400 text-xs font-['Space_Grotesk'] tracking-wider">BASE SETS</span>
                    </div>
                </div>
            </div>

            <!-- Quick Start (Medium Tile) -->
            <div class="col-span-12 md:col-span-6 lg:col-span-4 bg-[rgba(18,18,18,0.7)] backdrop-blur-xl border border-[#2A2A2A] border-[#FF8C00]/30 p-6 rounded-xl relative overflow-hidden group">
                <div class="relative z-10">
                    <h2 class="font-['Space_Grotesk'] text-2xl font-semibold text-white mb-4 uppercase tracking-tight">Quick Start</h2>
                    <div class="space-y-3">
                        <button class="w-full p-4 bg-zinc-900 border border-zinc-800 rounded flex items-center justify-between hover:border-[#FF8C00]/50 transition-all group/btn">
                            <div class="flex items-center gap-3">
                                <span class="material-symbols-outlined text-[#FF8C00]">auto_awesome</span>
                                <span class="font-['Space_Grotesk'] text-sm uppercase tracking-wider">AI Deck Generator</span>
                            </div>
                            <span class="material-symbols-outlined text-zinc-600 group-hover/btn:text-[#FF8C00] transition-colors">chevron_right</span>
                        </button>
                        <button class="w-full p-4 bg-zinc-900 border border-zinc-800 rounded flex items-center justify-between hover:border-[#FF8C00]/50 transition-all group/btn">
                            <div class="flex items-center gap-3">
                                <span class="material-symbols-outlined text-zinc-400">upload_file</span>
                                <span class="font-['Space_Grotesk'] text-sm uppercase tracking-wider">Import MTGO/Arena</span>
                            </div>
                            <span class="material-symbols-outlined text-zinc-600 group-hover/btn:text-[#FF8C00] transition-colors">chevron_right</span>
                        </button>
                    </div>
                </div>
                <!-- Background Accent -->
                <div class="absolute -right-10 -bottom-10 w-40 h-40 bg-[#FF8C00]/10 blur-3xl rounded-full group-hover:bg-[#FF8C00]/20 transition-all"></div>
            </div>

            <!-- Recent Decks (Row) -->
            <div class="col-span-12 mt-8">
                <div class="flex justify-between items-end mb-6">
                    <h2 class="font-['Space_Grotesk'] text-2xl font-semibold text-white uppercase tracking-tight">Active Deployments</h2>
                    <a class="text-[#FF8C00] font-['Space_Grotesk'] text-xs uppercase tracking-widest flex items-center gap-2 hover:gap-3 transition-all" href="{{ path('app_decks') }}">
                        View All Decks <span class="material-symbols-outlined text-sm">arrow_forward</span>
                    </a>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                    <!-- Deck Card 1 -->
                    <div class="bg-[#1A1B1E] border border-[#2A2A2A] hover:border-[#FF8C00]/50 transition-all rounded p-1 flex flex-col">
                        <div class="relative h-40 overflow-hidden rounded-sm mb-4">
                            <img alt="Inferno Overdrive Artwork" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuD4WEZRJoV1QlcF8X5gtasBf8lir_Y-8bks8KWyVRkLVyKIn-eBnMXFWK-VIPA86xec-QtRzV1BkbMwzE7HNRl6MCe-KG6cC8f_hPbxdUteQPQgesn1mmuixI3NPusk6OdPtNZh5NjkTk_-1fq78qNJsPLXFlBGhtXBJ5RIcVSl8FBlgURW_vk1XchnQ5ceggmMJCiLS4d-GW47RBLmxlbPHzfM30LQ-beuo8fDZork82qHJRyEMg06CIG6dpFi3iCCHNRHv5k__uWQ"/>
                            <div class="absolute top-2 right-2 bg-black/60 backdrop-blur px-2 py-1 rounded text-[10px] font-['Space_Grotesk'] text-[#FF8C00] border border-[#FF8C00]/30">MYTHIC</div>
                        </div>
                        <div class="px-3 pb-4">
                            <h3 class="font-['Space_Grotesk'] text-lg font-semibold text-white mb-1">Inferno Overdrive</h3>
                            <div class="flex items-center gap-1 mb-4">
                                <div class="w-3 h-3 rounded-full bg-red-600 border border-white/20"></div>
                                <span class="text-[10px] font-['Space_Grotesk'] text-zinc-500 uppercase tracking-wider">Mono Red Aggro</span>
                            </div>
                            <div class="flex justify-between items-center pt-3 border-t border-zinc-800">
                                <div class="flex items-center gap-2 text-zinc-400">
                                    <span class="material-symbols-outlined text-sm">analytics</span>
                                    <span class="text-[10px] font-['Space_Grotesk'] tracking-wider">68% WR</span>
                                </div>
                                <button class="text-zinc-500 hover:text-white transition-colors">
                                    <span class="material-symbols-outlined text-lg">more_vert</span>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Deck Card 2 -->
                    <div class="bg-[#1A1B1E] border border-[#2A2A2A] hover:border-[#FF8C00]/50 transition-all rounded p-1 flex flex-col">
                        <div class="relative h-40 overflow-hidden rounded-sm mb-4">
                            <img alt="Ethereal Tide Artwork" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuA16q1ToVlwfa6A4cdWhgfbm6p5Iu48wWiBBCsLEkDxU9_2Im5g6rynD-1PZohL2Xaqu5Pp4VLZ0Dd8qgyiemJPm4xkVOM2A_3C7bLWF4BZQIop46x-uv-P78bcpDVcBX-zaCxCmWzqAsbujvZTj8_P4UsC182Qh5dRvEzrrP4ObgZg4m2F7uMgD_5W56acwXpPVKSdFzzFkAJMj2mxhGHoDXnwtqgnQC_-45pp4veSqvcOiHPn2an_-d2nbK4EzyAEW8PJugXU3lRG"/>
                            <div class="absolute top-2 right-2 bg-black/60 backdrop-blur px-2 py-1 rounded text-[10px] font-['Space_Grotesk'] text-yellow-500 border border-yellow-500/30">RARE</div>
                        </div>
                        <div class="px-3 pb-4">
                            <h3 class="font-['Space_Grotesk'] text-lg font-semibold text-white mb-1">Ethereal Tide</h3>
                            <div class="flex items-center gap-1 mb-4">
                                <div class="w-3 h-3 rounded-full bg-blue-600 border border-white/20"></div>
                                <div class="w-3 h-3 rounded-full bg-green-600 border border-white/20 -ml-1"></div>
                                <span class="text-[10px] font-['Space_Grotesk'] text-zinc-500 uppercase tracking-wider">Simic Control</span>
                            </div>
                            <div class="flex justify-between items-center pt-3 border-t border-zinc-800">
                                <div class="flex items-center gap-2 text-zinc-400">
                                    <span class="material-symbols-outlined text-sm">analytics</span>
                                    <span class="text-[10px] font-['Space_Grotesk'] tracking-wider">54% WR</span>
                                </div>
                                <button class="text-zinc-500 hover:text-white transition-colors">
                                    <span class="material-symbols-outlined text-lg">more_vert</span>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Deck Card 3 -->
                    <div class="bg-[#1A1B1E] border border-[#2A2A2A] hover:border-[#FF8C00]/50 transition-all rounded p-1 flex flex-col">
                        <div class="relative h-40 overflow-hidden rounded-sm mb-4">
                            <img alt="Night's Whisper Artwork" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBCfMaMNMZlYiN1KdsDdo3I5hJBMcxvsxepVfuWu0eOWI0VwSfBI2X6BbiBNIR5xYNK7Yx1AGUu6Xlb24oOkQXDiiFZ1rQ6LhEthfTB1uHYgyqcqfQLuKSiza9EANSFVyn1DIiPPYKFdItelPuLOnxopPVB766uqhbg3R9_fhJhz5OjuLtlDMxRD467Vj6L8mww4ZGw4kGRGTmYXN_UzVpC0HGhK7yQK-eIoQorU2yW4pdhNjG1MQoKI2ByPi8NzyD72Yn0vLM5rFnF"/>
                            <div class="absolute top-2 right-2 bg-black/60 backdrop-blur px-2 py-1 rounded text-[10px] font-['Space_Grotesk'] text-zinc-400 border border-zinc-400/30">UNCOMMON</div>
                        </div>
                        <div class="px-3 pb-4">
                            <h3 class="font-['Space_Grotesk'] text-lg font-semibold text-white mb-1">Night's Whisper</h3>
                            <div class="flex items-center gap-1 mb-4">
                                <div class="w-3 h-3 rounded-full bg-purple-900 border border-white/20"></div>
                                <span class="text-[10px] font-['Space_Grotesk'] text-zinc-500 uppercase tracking-wider">Dimir Rogues</span>
                            </div>
                            <div class="flex justify-between items-center pt-3 border-t border-zinc-800">
                                <div class="flex items-center gap-2 text-zinc-400">
                                    <span class="material-symbols-outlined text-sm">analytics</span>
                                    <span class="text-[10px] font-['Space_Grotesk'] tracking-wider">61% WR</span>
                                </div>
                                <button class="text-zinc-500 hover:text-white transition-colors">
                                    <span class="material-symbols-outlined text-lg">more_vert</span>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Add New Deck -->
                    <a href="{{ path('app_deck_create') }}" class="border-2 border-dashed border-[#2A2A2A] hover:border-[#FF8C00]/50 transition-all rounded flex flex-col items-center justify-center min-h-[280px] group">
                        <div class="w-12 h-12 rounded-full bg-zinc-900 flex items-center justify-center mb-4 group-hover:bg-[#FF8C00]/20 transition-all">
                            <span class="material-symbols-outlined text-zinc-500 group-hover:text-[#FF8C00]">add</span>
                        </div>
                        <span class="font-['Space_Grotesk'] text-xs text-zinc-500 uppercase tracking-widest group-hover:text-white">Create New Deck</span>
                    </a>
                </div>
            </div>

            <!-- Tournament Stats -->
            <div class="col-span-12 md:col-span-4 bg-[rgba(18,18,18,0.7)] backdrop-blur-xl border border-[#2A2A2A] p-5 rounded-xl">
                <h3 class="font-['Space_Grotesk'] text-white text-sm mb-4 uppercase tracking-widest flex items-center gap-2">
                    <span class="material-symbols-outlined text-[#FF8C00] text-sm">trophy</span>
                    Recent Tournaments
                </h3>
                <div class="space-y-3">
                    <div class="flex items-center justify-between p-2 hover:bg-zinc-800/30 rounded transition-colors">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 bg-zinc-900 rounded border border-zinc-700 flex items-center justify-center">
                                <span class="text-[10px] font-['Space_Grotesk'] text-zinc-500">M</span>
                            </div>
                            <div>
                                <div class="text-xs text-white font-medium">Ragavan, Nimble Pilferer</div>
                                <div class="text-[10px] text-zinc-500 font-['Space_Grotesk']">Used in 4 Decks</div>
                            </div>
                        </div>
                        <div class="text-right">
                            <div class="text-xs text-[#FF8C00] font-['Space_Grotesk']">Maindeck</div>
                        </div>
                    </div>
                    <div class="flex items-center justify-between p-2 hover:bg-zinc-800/30 rounded transition-colors">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 bg-zinc-900 rounded border border-zinc-700 flex items-center justify-center">
                                <span class="text-[10px] font-['Space_Grotesk'] text-zinc-500">M</span>
                            </div>
                            <div>
                                <div class="text-xs text-white font-medium">The One Ring</div>
                                <div class="text-[10px] text-zinc-500 font-['Space_Grotesk']">Used in 2 Decks</div>
                            </div>
                        </div>
                        <div class="text-right">
                            <div class="text-xs text-[#FF8C00] font-['Space_Grotesk']">Maindeck</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-span-12 md:col-span-8 bg-[rgba(18,18,18,0.7)] backdrop-blur-xl border border-[#2A2A2A] p-5 rounded-xl">
                <h3 class="font-['Space_Grotesk'] text-white text-sm mb-4 uppercase tracking-widest">Format Meta-Share</h3>
                <div class="flex items-center gap-4 h-24">
                    <div class="flex-1 flex flex-col gap-2">
                        <div class="flex justify-between text-[10px] font-['Space_Grotesk'] text-zinc-400">
                            <span>COMMANDER</span>
                            <span>42%</span>
                        </div>
                        <div class="h-1.5 bg-zinc-800 rounded-full">
                            <div class="h-full bg-[#FF8C00] w-[42%] rounded-full shadow-[0_0_8px_rgba(255,140,0,0.5)]"></div>
                        </div>
                    </div>
                    <div class="flex-1 flex flex-col gap-2">
                        <div class="flex justify-between text-[10px] font-['Space_Grotesk'] text-zinc-400">
                            <span>MODERN</span>
                            <span>28%</span>
                        </div>
                        <div class="h-1.5 bg-zinc-800 rounded-full">
                            <div class="h-full bg-zinc-400 w-[28%] rounded-full"></div>
                        </div>
                    </div>
                    <div class="flex-1 flex flex-col gap-2">
                        <div class="flex justify-between text-[10px] font-['Space_Grotesk'] text-zinc-400">
                            <span>STANDARD</span>
                            <span>15%</span>
                        </div>
                        <div class="h-1.5 bg-zinc-800 rounded-full">
                            <div class="h-full bg-zinc-600 w-[15%] rounded-full"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>
{% endblock %}
