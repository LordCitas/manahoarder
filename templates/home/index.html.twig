{% extends 'base.html.twig' %}

{% block title %}ManaHoarder - Create & Manage Magic Decks{% endblock %}

{% block body %}
<main class="min-h-screen">
    <div class="max-w-[1440px] mx-auto p-8 lg:p-12">
        <!-- Hero Section -->
        <div class="mb-20 text-center">
            <h1 class="font-['Space_Grotesk'] text-[60px] lg:text-[80px] leading-[1.1] tracking-tighter font-bold text-[#FF8C00] mb-6 uppercase">
                Master Your Game
            </h1>
            <p class="text-xl lg:text-2xl text-zinc-300 max-w-3xl mx-auto mb-12 font-light">
                Create, refine, and compete with expertly crafted Magic decks. Manage your collection of competitive strategies and dominate tournaments.
            </p>
            
            <!-- CTA Buttons -->
            <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
                <a href="{{ path('app_deck_create') }}" class="px-8 py-4 bg-[#FF8C00] hover:bg-[#ff9d26] text-black font-['Space_Grotesk'] font-bold uppercase tracking-widest rounded-lg transition-all hover:shadow-lg hover:shadow-[#FF8C00]/50 flex items-center gap-3">
                    <span class="material-symbols-outlined">add</span>
                    Create Your First Deck
                </a>
                <a href="{{ path('app_decks') }}" class="px-8 py-4 bg-zinc-900 hover:bg-zinc-800 border-2 border-[#FF8C00]/50 hover:border-[#FF8C00] text-white font-['Space_Grotesk'] font-bold uppercase tracking-widest rounded-lg transition-all flex items-center gap-3">
                    <span class="material-symbols-outlined">folder_open</span>
                    Browse All Decks
                </a>
            </div>
        </div>

        <!-- Features Grid -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
            <!-- Feature 1: Deck Creation -->
            <div class="group bg-[rgba(18,18,18,0.7)] backdrop-blur-xl border border-[#2A2A2A] hover:border-[#FF8C00]/50 p-8 rounded-xl transition-all">
                <div class="w-16 h-16 bg-[#FF8C00]/20 rounded-lg flex items-center justify-center mb-6 group-hover:bg-[#FF8C00]/30 transition-all">
                    <span class="material-symbols-outlined text-4xl text-[#FF8C00]">build</span>
                </div>
                <h3 class="font-['Space_Grotesk'] text-xl font-bold text-white mb-3 uppercase tracking-wide">Build Decks</h3>
                <p class="text-zinc-400 text-sm leading-relaxed">
                    Search through thousands of Magic cards, build decks with format validation, and organize your strategies in an intuitive interface.
                </p>
            </div>

            <!-- Feature 2: Format Support -->
            <div class="group bg-[rgba(18,18,18,0.7)] backdrop-blur-xl border border-[#2A2A2A] hover:border-[#FF8C00]/50 p-8 rounded-xl transition-all">
                <div class="w-16 h-16 bg-[#FF8C00]/20 rounded-lg flex items-center justify-center mb-6 group-hover:bg-[#FF8C00]/30 transition-all">
                    <span class="material-symbols-outlined text-4xl text-[#FF8C00]">category</span>
                </div>
                <h3 class="font-['Space_Grotesk'] text-xl font-bold text-white mb-3 uppercase tracking-wide">Multiple Formats</h3>
                <p class="text-zinc-400 text-sm leading-relaxed">
                    Support for Standard, Modern, Commander, Legacy, Vintage, Pioneer, and Pauper with automatic legality checking.
                </p>
            </div>

            <!-- Feature 3: Tournament Management -->
            <div class="group bg-[rgba(18,18,18,0.7)] backdrop-blur-xl border border-[#2A2A2A] hover:border-[#FF8C00]/50 p-8 rounded-xl transition-all">
                <div class="w-16 h-16 bg-[#FF8C00]/20 rounded-lg flex items-center justify-center mb-6 group-hover:bg-[#FF8C00]/30 transition-all">
                    <span class="material-symbols-outlined text-4xl text-[#FF8C00]">trophy</span>
                </div>
                <h3 class="font-['Space_Grotesk'] text-xl font-bold text-white mb-3 uppercase tracking-wide">Tournaments</h3>
                <p class="text-zinc-400 text-sm leading-relaxed">
                    Create tournaments, manage participants, track results, and showcase your competitive achievements in the Magic community.
                </p>
            </div>
        </div>

        <!-- Main Content Section -->
        <div class="grid grid-cols-12 gap-6">
            <!-- Deck Showcase -->
            <div class="col-span-12 lg:col-span-8">
                <div class="mb-8">
                    <h2 class="font-['Space_Grotesk'] text-3xl font-bold text-white mb-2 uppercase tracking-tight">Powerful Deck Management</h2>
                    <p class="text-zinc-400">Build and refine competitive decks with real-time format validation</p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Benefit 1 -->
                    <div class="bg-[rgba(18,18,18,0.7)] backdrop-blur-xl border border-[#2A2A2A] p-6 rounded-xl">
                        <div class="flex items-start gap-4">
                            <div class="w-12 h-12 bg-[#FF8C00]/20 rounded flex items-center justify-center flex-shrink-0">
                                <span class="material-symbols-outlined text-[#FF8C00]">check_circle</span>
                            </div>
                            <div>
                                <h3 class="font-['Space_Grotesk'] font-bold text-white mb-2">Format Legality</h3>
                                <p class="text-sm text-zinc-400">Cards are validated against official format restrictions from Scryfall</p>
                            </div>
                        </div>
                    </div>

                    <!-- Benefit 2 -->
                    <div class="bg-[rgba(18,18,18,0.7)] backdrop-blur-xl border border-[#2A2A2A] p-6 rounded-xl">
                        <div class="flex items-start gap-4">
                            <div class="w-12 h-12 bg-[#FF8C00]/20 rounded flex items-center justify-center flex-shrink-0">
                                <span class="material-symbols-outlined text-[#FF8C00]">search</span>
                            </div>
                            <div>
                                <h3 class="font-['Space_Grotesk'] font-bold text-white mb-2">Card Search</h3>
                                <p class="text-sm text-zinc-400">Instant search through thousands of Magic cards with detailed information</p>
                            </div>
                        </div>
                    </div>

                    <!-- Benefit 3 -->
                    <div class="bg-[rgba(18,18,18,0.7)] backdrop-blur-xl border border-[#2A2A2A] p-6 rounded-xl">
                        <div class="flex items-start gap-4">
                            <div class="w-12 h-12 bg-[#FF8C00]/20 rounded flex items-center justify-center flex-shrink-0">
                                <span class="material-symbols-outlined text-[#FF8C00]">view_week</span>
                            </div>
                            <div>
                                <h3 class="font-['Space_Grotesk'] font-bold text-white mb-2">Deck Views</h3>
                                <p class="text-sm text-zinc-400">List and grid visualization modes for organizing and analyzing cards</p>
                            </div>
                        </div>
                    </div>

                    <!-- Benefit 4 -->
                    <div class="bg-[rgba(18,18,18,0.7)] backdrop-blur-xl border border-[#2A2A2A] p-6 rounded-xl">
                        <div class="flex items-start gap-4">
                            <div class="w-12 h-12 bg-[#FF8C00]/20 rounded flex items-center justify-center flex-shrink-0">
                                <span class="material-symbols-outlined text-[#FF8C00]">upload</span>
                            </div>
                            <div>
                                <h3 class="font-['Space_Grotesk'] font-bold text-white mb-2">Import Decks</h3>
                                <p class="text-sm text-zinc-400">Import deck lists from text format with automatic validation</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- CTA Button -->
                <div class="mt-8">
                    <a href="{{ path('app_deck_create') }}" class="inline-flex items-center gap-3 px-8 py-4 bg-[#FF8C00] hover:bg-[#ff9d26] text-black font-['Space_Grotesk'] font-bold uppercase tracking-widest rounded-lg transition-all hover:shadow-lg hover:shadow-[#FF8C00]/50">
                        <span class="material-symbols-outlined">arrow_forward</span>
                        Start Building
                    </a>
                </div>
            </div>

            <!-- Tournament Showcase -->
            <div class="col-span-12 lg:col-span-4">
                <div class="mb-8">
                    <h2 class="font-['Space_Grotesk'] text-3xl font-bold text-white mb-2 uppercase tracking-tight">Compete</h2>
                    <p class="text-zinc-400">Organize and manage tournaments</p>
                </div>

                <div class="bg-[rgba(18,18,18,0.7)] backdrop-blur-xl border border-[#FF8C00]/30 p-8 rounded-xl">
                    <div class="space-y-6">
                        <div>
                            <h3 class="font-['Space_Grotesk'] font-bold text-white mb-3 uppercase text-sm tracking-wide">Tournament Features</h3>
                            <ul class="space-y-3">
                                <li class="flex items-center gap-3 text-sm text-zinc-400">
                                    <span class="material-symbols-outlined text-[#FF8C00] text-sm">done</span>
                                    Create custom tournaments
                                </li>
                                <li class="flex items-center gap-3 text-sm text-zinc-400">
                                    <span class="material-symbols-outlined text-[#FF8C00] text-sm">done</span>
                                    Manage participants
                                </li>
                                <li class="flex items-center gap-3 text-sm text-zinc-400">
                                    <span class="material-symbols-outlined text-[#FF8C00] text-sm">done</span>
                                    Track results
                                </li>
                                <li class="flex items-center gap-3 text-sm text-zinc-400">
                                    <span class="material-symbols-outlined text-[#FF8C00] text-sm">done</span>
                                    Set format rules
                                </li>
                            </ul>
                        </div>

                        <a href="{{ path('app_tournaments') }}" class="w-full px-6 py-3 bg-[#FF8C00] hover:bg-[#ff9d26] text-black font-['Space_Grotesk'] font-bold uppercase tracking-widest rounded-lg transition-all hover:shadow-lg hover:shadow-[#FF8C00]/50 flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined">sports</span>
                            View Tournaments
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bottom CTA Section -->
        <div class="mt-20 bg-gradient-to-r from-[#FF8C00]/10 to-transparent border border-[#FF8C00]/30 rounded-xl p-12 text-center">
            <h2 class="font-['Space_Grotesk'] text-3xl font-bold text-white mb-4 uppercase tracking-tight">
                Ready to Compete?
            </h2>
            <p class="text-lg text-zinc-300 mb-8 max-w-2xl mx-auto">
                Join the Magic community and start building your competitive deck collection today.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a href="{{ path('app_deck_create') }}" class="px-8 py-3 bg-[#FF8C00] hover:bg-[#ff9d26] text-black font-['Space_Grotesk'] font-bold uppercase tracking-widest rounded-lg transition-all hover:shadow-lg hover:shadow-[#FF8C00]/50 flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined">add</span>
                    Create Deck
                </a>
                <a href="{{ path('app_tournaments') }}" class="px-8 py-3 bg-zinc-900 hover:bg-zinc-800 border-2 border-[#FF8C00]/50 hover:border-[#FF8C00] text-white font-['Space_Grotesk'] font-bold uppercase tracking-widest rounded-lg transition-all flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined">trophy</span>
                    View Tournaments
                </a>
            </div>
        </div>
    </div>
</main>
{% endblock %}
